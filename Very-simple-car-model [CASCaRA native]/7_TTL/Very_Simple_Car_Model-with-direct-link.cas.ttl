d:Very_Simple_Car_Model-with-direct-link_ontology
	a owl:Ontology ;
	dcterms:contributor "cecilia.tonelli@collins.com" ,
		"oskar.dungern@gfse.org" ;
	dcterms:license "https://creativecommons.org/licenses/by-sa/4.0/" ;
	owl:versionInfo "2026-07-03" .

d:Very_Simple_Car_Model-with-direct-link
	a cas:Package ;
	rdfs:label "Very Simple Car Model-with-direct-link" ;
	rdfs:comment "An example where a car has identical wheels at four defined positions. The wheels are related with a direct link." ;
	dcterms:modified "2026-01-17T22:38:19.595Z"^^xs:dateTime .

#################################################################
# Graph Items
#################################################################

cas:Package
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Package" ;
	skos:definition "A CASCaRA meta-model item used for packages comprising entities, relationships and potentially nested packages, both classes and instances." .

cas:Package_shape
	a sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) .

cas:Organizer
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer" ;
	skos:definition "An element organizing model elements. An example is a list of requirements or a diagram using a certain notation." .

cas:Organizer_shape
	a sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape .

cas:Root
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Hierarchy Root" ;
	skos:definition "A subclass of CASCaRA organizer serving as a root for hierarchically organized graph elements." .

cas:Root_shape
	a sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:lists_shape .

cas:Outline
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Outline" ;
	skos:definition "A subclass of CASCaRA organizer comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

cas:Outline_shape
	a sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape ;
	sh:property cas:lists_shape .

FMC:Actor
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Actor"@en ,
		"Akteur"@de ,
		"Acteur"@fr ;
	rdfs:comment "<p>An 'Actor' is a fundamental model element type representing an active entity, be it an activity, a process step, a function, a system component or a role.</p><p>The particular use or original type is specified with a [[dcterms:type]] property of the 'FMC:Actor'. A value of that property should be an ontology-term, such as [[bpmn:processStep]].</p>"@en ,
		"<p>Ein 'Akteur' ist ein fundamentaler Modellelementtyp, der eine aktive Entität darstellt, sei es eine Aktivität, ein Prozessschritt, eine Funktion, eine Systemkomponente oder eine Rolle.</p><p>Die spezielle Verwendung oder der ursprüngliche Typ wird mit einer [[dcterms:type]] Eigenschaft von 'FMC:Actor' spezifiziert. Die Werte dieser Eigenschaft können Ontologiebegriffe sein, wie z.B. [[bpmn:timer]].</p>"@de ,
		"<p>Un 'Acteur' est un type d'élément de modèle fondamental représentant une entité active, qu'il s'agisse d'une activité, d'une étape de processus, d'une fonction, d'un composant de système ou d'un rôle.</p><p>L'utilisation particulière ou le type original est spécifié avec une propriété [[dcterms:type]] de 'FMC:Actor'. Les valeurs de cette propriété peuvent être des termes d'ontologie, tels que [[bpmn:timer]].</p>"@fr ;
	cas:icon "\"□\"" .

FMC:Actor_shape
	a sh:NodeShape ;
	sh:targetClass FMC:Actor ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape .

cas:hasPart
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "has part"@en ;
	rdfs:comment "A [[Component]] has a [[Component]]."@en .

cas:hasPart_shape
	a sh:NodeShape ;
	sh:targetClass cas:hasPart ;
	sh:property cas:linksSource_shape ;
	sh:property cas:linksTarget_shape .

cas:Category
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category" ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)." .

cas:Category_shape
	a sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 ;
	sh:maxLength 32 .

cas:linksSource
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to source" ;
	skos:definition "Connects the source of a reified relationship." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksSource_shape
	a sh:PropertyShape ;
	sh:path cas:linksSource ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:linksTarget
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to target" ;
	skos:definition "Connects the target of a reified relationship or an organizer." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksTarget_shape
	a sh:PropertyShape ;
	sh:path cas:linksTarget ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:lists
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "lists" ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship cas:Organizer ) ] .

cas:lists_shape
	a sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] [ sh:class cas:Organizer ] ) .

o:TireDimension
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "tire dimension"@en ;
	skos:definition "The dimension (size) of a tire."@en .

o:TireDimension_shape
	a sh:PropertyShape ;
	sh:path o:TireDimension ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

o:hasWheel_frontRight
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "wheel at position front-right"@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	rdfs:range o:Wheel .

o:hasWheel_frontRight_shape
	a sh:PropertyShape ;
	sh:path o:hasWheel_frontRight ;
	sh:class o:Wheel ;
	sh:minCount 1 ;
	sh:maxCount 1 .

o:hasWheel_frontLeft
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "wheel at position front-left"@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	rdfs:range o:Wheel .

o:hasWheel_frontLeft_shape
	a sh:PropertyShape ;
	sh:path o:hasWheel_frontLeft ;
	sh:class o:Wheel ;
	sh:minCount 1 ;
	sh:maxCount 1 .

o:hasWheel_backRight
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "wheel at position back-right"@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	rdfs:range o:Wheel .

o:hasWheel_backRight_shape
	a sh:PropertyShape ;
	sh:path o:hasWheel_backRight ;
	sh:class o:Wheel ;
	sh:minCount 1 ;
	sh:maxCount 1 .

o:hasWheel_backLeft
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "wheel at position back-left"@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	rdfs:range o:Wheel .

o:hasWheel_backLeft_shape
	a sh:PropertyShape ;
	sh:path o:hasWheel_backLeft ;
	sh:class o:Wheel ;
	sh:minCount 1 ;
	sh:maxCount 1 .

o:Vehicle
	rdfs:subClassOf FMC:Actor ;
	rdfs:label "Vehicle"@en ;
	rdfs:comment "<p>A 'Vehicle' is a ...</p>"@en .

o:Vehicle_shape
	a sh:NodeShape ;
	sh:targetClass o:Vehicle ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape .

o:Car
	rdfs:subClassOf o:Vehicle ;
	rdfs:label "Car"@en ;
	rdfs:comment "<p>A 'Car' is...</p>"@en .

o:Car_shape
	a sh:NodeShape ;
	sh:targetClass o:Car ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape ;
	sh:property o:hasWheel_frontRight_shape ;
	sh:property o:hasWheel_frontLeft_shape ;
	sh:property o:hasWheel_backRight_shape ;
	sh:property o:hasWheel_backLeft_shape .

o:Wheel
	rdfs:subClassOf FMC:Actor ;
	rdfs:label "Wheel"@en ;
	rdfs:comment "<p> A 'Wheel' is... </p>"@en .

o:Wheel_shape
	a sh:NodeShape ;
	sh:targetClass o:Wheel ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property o:TireDimension_shape .

