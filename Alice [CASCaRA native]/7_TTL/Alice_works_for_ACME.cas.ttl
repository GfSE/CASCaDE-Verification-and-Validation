
@prefix cas: <https://product-information-graph.org/ontology/2026-05-08/metamodel#> .
@prefix skos: <https://www.w3.org/TR/skos-reference/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <http://schema.org/> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix o: <https://alice.org/ontology#> .
@prefix d: <https://alice.org/data#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

d:Alice_works_for_ACME_ontology
	a owl:Ontology ;
	dcterms:contributor "mailto:oskar.dungern@gfse.org" ;
	dcterms:license "https://creativecommons.org/licenses/by-sa/4.0/" ;
	owl:versionInfo "2026-07-03" .

d:Alice_works_for_ACME
	a cas:Package ;
	rdfs:label "Alice works for ACME"@en ;
	dcterms:modified "2026-01-20T09:38:26.464Z"^^xs:dateTime .

#################################################################
# Graph Items
#################################################################

cas:Organizer
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer"@en ;
	skos:definition "An element organizing model elements. An example is a list of requirements or a diagram using a certain notation."@en .

cas:Organizer_shape
	a sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape .

cas:Package
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Package"@en ;
	skos:definition "A CASCaRA meta-model item used for packages comprising entities, relationships and potentially nested packages, both classes and instances." .

cas:Package_shape
	a sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) .

cas:Root
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Package Root"@en ;
	skos:definition "A subclass of CASCaRA organizer serving as a root for trees and tables."@en .

cas:Root_shape
	a sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:lists_shape .

cas:Outline
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Outline"@en ;
	skos:definition "A subclass of CASCaRA organizer comprising all information items of a human-readable document. As usual, the outline is hierarchically organized."@en .

cas:Outline_shape
	a sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Category_shape ;
	sh:property cas:lists_shape .

cas:Category
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category"@en ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)."@en .

cas:Category_shape
	a sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 ;
	sh:maxLength 32 .

cas:Link
	a owl:ObjectProperty ;
	rdfs:label "linked with"@en ;
	skos:definition "A CASCaRA meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element"@en ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksSource
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to source"@en ;
	skos:definition "Connects the source of a reified relationship."@en ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksSource_shape
	a sh:PropertyShape ;
	sh:path cas:linksSource ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:linksTarget
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to target"@en ;
	skos:definition "Connects the target of a reified relationship or an organizer."@en ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksTarget_shape
	a sh:PropertyShape ;
	sh:path cas:linksTarget ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:lists
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "lists"@en ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer."@en ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship cas:Organizer ) ] .

cas:lists_shape
	a sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] [ sh:class cas:Organizer ] ) .

cas:Person
	a owl:Class ;
	rdfs:subClassOf schema:Person ;
	rdfs:label "Person"@en ;
	skos:definition "A person (alive, dead, undead, or fictional)."@en .

cas:Person_shape
	a sh:NodeShape ;
	sh:targetClass cas:Person ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:familyName_shape ;
	sh:property cas:givenName_shape ;
	sh:property cas:birthDate_shape .

cas:Organization
	a owl:Class ;
	rdfs:subClassOf schema:Organization ;
	rdfs:label "Organization"@en ;
	skos:definition "An organization such as a school, NGO, corporation, club, etc."@en .

cas:Organization_shape
	a sh:NodeShape ;
	sh:targetClass cas:Organization ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:legalName_shape ;
	sh:property cas:taxID_shape .

cas:birthDate
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf schema:birthDate ;
	rdfs:label "birth date"@en ;
	skos:definition "Date of birth."@en .

cas:birthDate_shape
	a sh:PropertyShape ;
	sh:path cas:birthDate ;
	sh:datatype xs:date ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:familyName
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf schema:familyName ;
	rdfs:label "family name"@en ;
	skos:definition "Family name. In the U.S., the last name of a Person."@en .

cas:familyName_shape
	a sh:PropertyShape ;
	sh:path cas:familyName ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:givenName
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf schema:givenName ;
	rdfs:label "given name"@en ;
	skos:definition "Given name. In the U.S., the first name of a Person."@en .

cas:givenName_shape
	a sh:PropertyShape ;
	sh:path cas:givenName ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:legalName
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf schema:legalName ;
	rdfs:label "legal name"@en ;
	skos:definition "The official name of the organization, e.g. the registered company name."@en .

cas:legalName_shape
	a sh:PropertyShape ;
	sh:path cas:legalName ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:taxID
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf schema:taxID ;
	rdfs:label "tax ID"@en ;
	skos:definition "The Tax / Fiscal ID of the organization or person, e.g. the TIN in the US or the CIF/NIF in Spain."@en .

cas:taxID_shape
	a sh:PropertyShape ;
	sh:path cas:taxID ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:WorksFor
	a owl:Class ;
	rdfs:subClassOf schema:WorksFor ;
	rdfs:label "works for"@en ;
	skos:definition "Organizations that the person works for."@en .

cas:WorksFor_shape
	a sh:NodeShape ;
	sh:targetClass cas:WorksFor ;
	sh:property o:Employee_shape ;
	sh:property o:Employer_shape .

o:Employee
	rdfs:subPropertyOf cas:linksSource ;
	rdfs:label "employee"@en ;
	skos:definition "The employee in a 'worksFor' relationship"@en ;
	rdfs:range cas:Person .

o:Employee_shape
	a sh:PropertyShape ;
	sh:path o:Employee ;
	sh:class cas:Person .

o:Employer
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "employer"@en ;
	skos:definition "The employer in a 'worksFor' relationship"@en ;
	rdfs:range cas:Organization .

o:Employer_shape
	a sh:PropertyShape ;
	sh:path o:Employer ;
	sh:class cas:Organization .

d:ACME
	a cas:Organization ;
	rdfs:label "ACME Corp."@en ;
	dcterms:modified "2026-01-20T09:38:26.464Z"^^xs:dateTime ;
	cas:legalName "ACME Corp." ;
	cas:taxID "DE_123456789" .

d:Alice
	a cas:Person ;
	rdfs:label "Alice"@en ;
	dcterms:modified "2026-01-20T09:38:26.464Z"^^xs:dateTime ;
	cas:familyName "Carpenter" ;
	cas:givenName "Alice" .

d:Alice_worksFor_ACME
	a cas:WorksFor ;
	dcterms:modified "2026-01-20T09:38:26.464Z"^^xs:dateTime ;
	o:Employee d:Alice ;
	o:Employer d:ACME .

d:Root_Alice_worksFor_ACME
	a cas:Root ;
	rdfs:label "Package Root"@en ;
	rdfs:comment "... anchoring all outlines of this graph (package)"@en ;
	dcterms:modified "2026-01-17T22:38:20.041Z"^^xs:dateTime ;
	cas:lists d:ACME ,
		d:Alice .


#################################################################
# Metamodel Class Shapes
#################################################################

cas:Property_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:DatatypeProperty ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:DatatypeProperty ] [ sh:path rdfs:subPropertyOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path sh:defaultValue ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:composes ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Property_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:DatatypeProperty ;
	sh:sparql [
		sh:message "Property class must have a corresponding PropertyShape with at least sh:datatype defined" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:PropertyShape ;
						sh:path $this ;
						sh:datatype ?dt .
				}
			}
		"""
	] .

cas:Link_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:ObjectProperty ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:ObjectProperty ] [ sh:path rdfs:subPropertyOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:range ; sh:minCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Link_shape_requirement_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:ObjectProperty ;
	sh:sparql [
		sh:message "Link class must have a corresponding PropertyShape with at least sh:class or sh:or constraint defined" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:PropertyShape ;
						sh:path $this .
					FILTER ( EXISTS { ?shape sh:class ?c } || EXISTS { ?shape sh:or ?o } )
				}
			}
		"""
	] .

cas:Enumeration_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass owl:Class ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:enumeratedValue ; sh:minCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Enumeration_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass owl:Class ;
	sh:sparql [
		sh:message "Enumeration class must have at least one valid enumeratedValue" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					$this cas:enumeratedValue ?value .
				}
			}
		"""
	] .

cas:Entity_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Entity ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:icon ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Entity_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Entity ;
	sh:sparql [
		sh:message "Entity class should have a corresponding NodeShape with sh:targetClass constraint" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Entity shape should have sh:property for each enumeratedProperty defined in the class" ;
		sh:select """
			SELECT $this ?prop
			WHERE {
				$this cas:enumeratedProperty ?prop .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?propShape .
					?propShape sh:path ?prop .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Entity shape should have sh:property for each enumeratedTargetLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedTargetLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] .

cas:Relationship_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Relationship ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:icon ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Relationship_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Relationship ;
	sh:sparql [
		sh:message "Relationship class should have a corresponding NodeShape with sh:targetClass constraint" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedProperty defined in the class" ;
		sh:select """
			SELECT $this ?prop
			WHERE {
				$this cas:enumeratedProperty ?prop .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?propShape .
					?propShape sh:path ?prop .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedSourceLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedSourceLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedTargetLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedTargetLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] .

