	rdf:type IREB:Requirement ;
	rdfs:label "Data Volume" ;
	rdfs:comment "<p>The data store MUST support a total volume up to 850 GB.</p>" ;
	SpecIF:Priority SpecIF:priorityHigh ;
	dcterms:modified "2020-10-17T10:00:00+01:00" .

d:Req-0Z7916e2872e78ecadc50feddc00918a
	rdf:type IREB:Requirement ;
	rdfs:label "Consistency" ;
	rdfs:comment "<p>The data store MUST be consistent at all times.</p>" ;
	SpecIF:Priority SpecIF:priorityHigh ;
	dcterms:modified "2020-10-17T10:00:00+01:00" .

d:Req-2b9016e2872e78ecadc50feddc0013Ac
	rdf:type IREB:Requirement ;
	rdfs:label "Response Time" ;
	rdfs:comment "<p>The system SHOULD respond on user queries within 300 ms.</p>" ;
	SpecIF:Priority SpecIF:priorityMedium ;
	dcterms:modified "2020-10-17T10:00:00+01:00" .

