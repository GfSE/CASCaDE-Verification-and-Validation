oslc_rm:satisfies
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "satisfies"@en ,
		"erfüllt"@de ,
		"satisfait"@fr ;
	skos:definition "<p>The object is satisfied by the subject. <small>(<i>source: <a href=\"http://open-services.net/\">OSLC</a></i>)</small></p><p>SpecIF suggests that the subject is confined to a model element, e.g, a [[FMC:Actor]] or [[FMC:State]], and the object is confined to a [[IREB:Requirement]]. More concretely, an example for this type of statement is 'Component-X <em>satisfies</em> 'Requirement-4711'.</p>"@en ;
	dcterms:modified "2016-05-26T08:59:00+02:00" .

oslc_rm:satisfies-toSource
	rdfs:subPropertyOf cas:linksSource ;
	rdfs:label "oslc_rm:satisfies to source" ;
	rdfs:comment "Connects the source of oslc_rm:satisfies" ;
	rdfs:domain oslc_rm:satisfies ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
		)] .

oslc_rm:satisfies-toTarget
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "oslc_rm:satisfies to target" ;
	rdfs:comment "Connects the target of oslc_rm:satisfies" ;
	rdfs:domain oslc_rm:satisfies ;
	rdfs:range IREB:Requirement .

casShapes_oslc_rm:satisfies
	rdf:type sh:NodeShape ;
	sh:targetClass oslc_rm:satisfies ;
	sh:property [ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ;
	sh:property [ 
		sh:path oslc_rm:satisfies-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path oslc_rm:satisfies-toTarget ;
		sh:or (
			[ sh:class IREB:Requirement ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

