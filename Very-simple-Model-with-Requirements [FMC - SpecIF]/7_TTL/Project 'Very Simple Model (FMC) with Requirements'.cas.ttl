
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <https://www.w3.org/TR/skos-reference/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix casShapes_dcterms: <https://product-information-graph.org/v0.2/ontology/shapes/dcterms#> .
@prefix FMC: <http://fmc-modeling.org#> .
@prefix casShapes_FMC: <https://product-information-graph.org/v0.2/ontology/shapes/FMC#> .
@prefix IREB: <https://cpre.ireb.org/en/downloads-and-resources/glossary#> .
@prefix casShapes_IREB: <https://product-information-graph.org/v0.2/ontology/shapes/IREB#> .
@prefix ReqIF: <https://www.prostep.org/fileadmin/downloads/PSI_ImplementationGuide_ReqIF_V1-7.pdf#> .
@prefix casShapes_ReqIF: <https://product-information-graph.org/v0.2/ontology/shapes/ReqIF#> .
@prefix oslc_rm: <http://open-services.net/ns/rm#> .
@prefix casShapes_oslc_rm: <https://product-information-graph.org/v0.2/ontology/shapes/oslc_rm#> .
@prefix cas: <https://product-information-graph.org/v0.2/metamodel#> .
@prefix casShapes_cas: <https://product-information-graph.org/v0.2/ontology/shapes/cas#> .
@prefix SpecIF: <https://specif.de/v1.2/schema#> .
@prefix casShapes_SpecIF: <https://product-information-graph.org/v0.2/ontology/shapes/SpecIF#> .

@prefix o: <https://product-information-graph.org/v0.2/ontology#> .
@prefix d: <https://product-information-graph.org/examples/09_Very-Simple-Model-FMC-with-Requirements.specif.zip#> .

#################################################################
# Project Metadata
#################################################################

d:
	rdf:type owl:Ontology ;
	rdfs:label "Project 'Very Simple Model (FMC) with Requirements'" ;
	owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ,
		<http://www.w3.org/2000/01/rdf-schema#> ;
	dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
	dcterms:modified "2026-05-14T08:07:58.531Z" .

#################################################################
# CASCaRA Metamodel and Semantic Infrastructure
#################################################################

cas:Enumeration
	rdf:type owl:Class ;
	rdfs:label "Enumeration" ;
	skos:definition "A CASCaRA meta-model item used for value enumerations." .

casShapes_cas:Enumeration
	rdf:type sh:NodeShape .

cas:Entity
	rdf:type owl:Class ;
	rdfs:label "Entity" ;
	skos:definition "A CASCaRA meta-model item used for entities (aka resources or artifacts)." .

casShapes_cas:Entity
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Entity ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

cas:Organizer
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer" ;
	skos:definition "A CASCaRA meta-model item for organizing model-elements. An example is a list of requirements or a diagram using a certain notation." .

casShapes_cas:Organizer
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Package
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Package" ;
	skos:definition "A subclass of cas:Organizer used for a partial graph selected for exchange or access permissions." .

casShapes_cas:Package
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Root
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Root" ;
	skos:definition "A subclass of cas:Organizer serving as a root for trees and tables." .

casShapes_cas:Root
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Tree
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Tree" ;
	skos:definition "A subclass of cas:Organizer for strictly hierarchical data structures referencing entities and relationships." .

casShapes_cas:Tree
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Tree ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Outline
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Tree ;
	rdfs:label "Outline" ;
	skos:definition "A subclass of cas:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

casShapes_cas:Outline
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Table
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Table" ;
	skos:definition "A subclass of cas:Organizer representing a table showing selected model elements." .

casShapes_cas:Table
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Table ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:shows .

cas:Relationship
	rdf:type owl:Class ;
	rdfs:label "Relationship" ;
	skos:definition "A CASCaRA meta-model item used for reified relationships (aka predicates)." .

casShapes_cas:Relationship
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Relationship ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:linksSource ,
		casShapes_cas:linksTarget .

cas:Property
	rdf:type owl:DatatypeProperty ;
	rdfs:label "Property" ;
	skos:definition "A CASCaRA meta-model item used for properties (aka attributes)." .

casShapes_cas:Property
	rdf:type sh:PropertyShape ;
	sh:path cas:Property ;
	sh:datatype xs:anyType .

cas:Diagram
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

casShapes_cas:Diagram
	rdf:type sh:PropertyShape ;
	sh:path cas:Diagram ;
	sh:datatype xs:string ;
	sh:minCount "0" .

cas:Category
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category" ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)." .

casShapes_cas:Category
	rdf:type sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:maxLength "32" ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Notation
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Category ;
	rdfs:label "Notation" ;
	skos:definition "A reference to a notation defining the syntax and semantics of a diagram." .

casShapes_cas:Notation
	rdf:type sh:PropertyShape ;
	sh:path cas:Notation ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Link
	rdf:type owl:ObjectProperty ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "linked with" ;
	skos:definition "A PIG meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element." .

casShapes_cas:Link
	rdf:type sh:PropertyShape ;
	sh:path cas:Link ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:linksSource
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to source" ;
	skos:definition "Connects the source of a reified relationship." .

casShapes_cas:linksSource
	rdf:type sh:PropertyShape ;
	sh:path cas:linksSource ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:linksTarget
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to target" ;
	skos:definition "Connects the target of a reified relationship or an organizer." .

casShapes_cas:linksTarget
	rdf:type sh:PropertyShape ;
	sh:path cas:linksTarget ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:lists
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
			cas:Organizer
		)] ;
	rdfs:label "lists" ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer." .

casShapes_cas:lists
	rdf:type sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
			[ sh:class cas:Organizer ]
		) .

cas:shows
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "shows" ;
	skos:definition "Shows an entity or a relationship." .

casShapes_cas:shows
	rdf:type sh:PropertyShape ;
	sh:path cas:shows ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:depicts
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:range cas:Entity ;
	rdfs:label "depicts" ;
	skos:definition "Depicts an entity; inverse of uml:ownedDiagram." .

casShapes_cas:depicts
	rdf:type sh:PropertyShape ;
	sh:path cas:depicts ;
	sh:or (
			[ sh:class cas:Entity ]
		) .

#################################################################
# Data Types with Enumerated Values
#################################################################

SpecIF:Priority-Enumeration
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Enumeration ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	dcterms:modified "2016-05-26T08:59:00+02:00" ;
	sh:datatype xs:string ;
	owl:oneOf (
			SpecIF:priorityHigh
			SpecIF:priorityMedium
			SpecIF:priorityLow
		) .
SpecIF:priorityHigh
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "high"@en ,
		"hoch"@de ,
		"haut"@fr .
SpecIF:priorityMedium
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "medium"@en ,
		"mittel"@de ,
		"moyen"@fr .
SpecIF:priorityLow
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "low"@en ,
		"niedrig"@de ,
		"bas"@fr .

#################################################################
# Ontology - Property Classes
#################################################################

# Skipping implicit property: rdfs:label

# Skipping implicit property: rdfs:comment

# Skipping implicit property: cas:Diagram

# Skipping implicit property: cas:Category

SpecIF:Priority
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	rdfs:range SpecIF:Priority-Enumeration .

casShapes_SpecIF:Priority
	rdf:type sh:PropertyShape ;
	sh:path SpecIF:Priority ;
	sh:maxCount "1" ;
	sh:class SpecIF:Priority-Enumeration .

o:PC-Diagram-10900558082
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "cas:Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

o:PC-Diagram-10900558082_shape
	rdf:type sh:PropertyShape ;
	sh:path o:PC-Diagram-10900558082 ;
	sh:datatype xs:string .

#################################################################
# Ontology - Entity Classes
#################################################################

SpecIF:Paragraph
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Paragraph"@en ,
		"Textabsatz"@de ,
		"Paragraphe"@fr ;
	skos:definition "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

casShapes_SpecIF:Paragraph
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:Paragraph ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Category .

cas:View
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "View" ;
	skos:definition "A PIG organizer class representing a diagram with certain model-elements for a given communication purpose." ;
	cas:Icon "▣" .

casShapes_cas:View
	rdf:type sh:NodeShape ;
	sh:targetClass cas:View ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Category .

FMC:Actor
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Actor"@en ,
		"Akteur"@de ,
		"Acteur"@fr ;
	skos:definition "<p>An 'Actor' is a fundamental model element type representing an active entity, be it an activity, a process step, a function, a system component or a role.</p><p>The  particular use or original type is specified with a [[dcterms:type]] property of the 'FMC:Actor'. A value of that property should be an ontology-term, such as [[bpmn:processStep]].</p>"@en ,
		"<p>Ein 'Akteur' ist ein fundamentaler Modellelementtyp, der eine aktive Entität darstellt, sei es eine Aktivität, ein Prozessschritt, eine Funktion, eine Systemkomponente oder eine Rolle.</p><p>Die spezielle Verwendung oder der ursprüngliche Typ wird mit einer [[dcterms:type]] Eigenschaft von 'FMC:Actor' spezifiziert. Die Werte dieser Eigenschaft können Ontologiebegriffe sein, wie z.B. [[bpmn:timer]].</p>"@de ,
		"<p>Un 'Acteur' est un type d'élément de modèle fondamental représentant une entité active, qu'il s'agisse d'une activité, d'une étape de processus, d'une fonction, d'un composant de système ou d'un rôle.</p><p>L'utilisation particulière ou le type original est spécifié avec une propriété [[dcterms:type]] de 'FMC:Actor'. Les valeurs de cette propriété peuvent être des termes d'ontologie, tels que [[bpmn:timer]].</p>"@fr ;
	cas:Icon "&#x25A1;" .

casShapes_FMC:Actor
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Actor ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

FMC:State
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "State"@en ,
		"Zustand"@de ,
		"État"@fr ;
	skos:definition "<p>A 'State' is a fundamental model element type representing a passive entity, be it a value, a condition, an information storage or even a physical shape.</p><p>The particular use or the original type is specified with a [[dcterms:type]] property of the 'FMC:State'. A value of that property should bean  ontology-term, such as [[bpmn:dataObject]].</p>"@en ,
		"<p>Ein 'Zustand' ist ein fundamentaler Modellelementtyp, der eine passive Entität darstellt, sei es ein Wert, ein Dokument, ein Informationsspeicher, eine Bedingung oder eine physische Beschaffenheit.</p><p>Die spezielle Verwendung oder der ursprüngliche Typ wird mit einer [[dcterms:type]] Eigenschaft von 'FMC:State' spezifiziert. Die Werte dieser Eigenschaft können Ontologiebegriffe sein, wie z.B. [[ArchiMate:DataObject]].</p>"@de ,
		"<p>Un 'État' est un type d'élément de modèle fondamental représentant une entité passive, qu'il s'agisse d'une valeur, d'une condition, d'un stockage d'informations ou même d'une forme physique.</p><p>L'utilisation particulière ou le type original est spécifié avec une propriété [[dcterms:type]] de 'FMC:State'. Les valeurs de cette propriété peuvent être des termes d'ontologie, tels que [[ArchiMate:DataObject]].</p>"@fr ;
	cas:Icon "&#x25CB;" .

casShapes_FMC:State
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:State ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

FMC:Event
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Event"@en ,
		"Ereignis"@de ,
		"Évenement"@fr ;
	skos:definition "<p>An 'Event' is a fundamental model element type representing a time reference, a change in condition/value or more generally a synchronization primitive.</p><p>The particular use or the original type is specified with a [[dcterms:type]] property of the 'FMC:Event'. A value of that property should be an ontology-term, such as [[bpmn:startEvent]].</p>"@en ,
		"<p>Ein 'Ereignis' ist ein fundamentaler Modellelementtyp, der eine Zeitreferenz, eine Änderung einer Bedingung/eines Wertes oder allgemeiner ein Synchronisationsmittel darstellt.</p><p>Die spezielle Verwendung oder der ursprüngliche Typ wird mit einer [[dcterms:type]] Eigenschaft von 'FMC:Event' spezifiziert. Die Werte dieser Eigenschaft sollen Ontologiebegriffe sein, wie z.B. [[bpmn:startEvent]].</p>"@de ,
		"<p>Un 'Événement' est un type d'élément de modèle fondamental représentant une référence temporelle, un changement de condition/valeur ou plus généralement une primitive de synchronisation.</p><p>L'utilisation particulière ou le type original est spécifié avec une propriété [[dcterms:type]] de 'FMC:Event'. Les valeurs de cette propriété peuvent être des termes d'ontologie, tels que [[bpmn:startEvent]].</p>"@fr ;
	cas:Icon "&#x2662;" .

casShapes_FMC:Event
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Event ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

IREB:Requirement
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Requirement"@en ,
		"Anforderung"@de ,
		"Exigence"@fr ;
	skos:definition "<p>A 'Requirement' is a singular documented physical and functional need that a particular design, product or process must be able to perform. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>A condition or capability needed by a user to solve a problem or achieve an objective.</li><li>A condition or capability that must be met or possessed by a system or system component to satisfy a contract, standard, specification, or other formally imposed documents.</li><li>A documented representation of a condition or capability as in (1) or (2).</li></ol><p>Note: The definition above is the classic one from IEEE Std 610.12 of 1990. Alternatively, we also give a more modern definition:</p><ol><li>A need perceived by a stakeholder.</li><li>A capability or property that a system shall have.</li><li>A documented representation of a need, capability or property.</li></ol>"@en ,
		"<p>Eine 'Anforderung' ist ein einzelnes dokumentiertes physisches und funktionales Bedürfnis, das ein bestimmter Entwurf, ein Produkt oder ein Prozess erfüllen muss. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>Eine Bedingung oder Fähigkeit, die ein Benutzer benötigt, um ein Problem zu lösen oder ein Ziel zu erreichen.</li><li>Eine Bedingung oder Fähigkeit, die ein System oder eine Systemkomponente erfüllen oder besitzen muss, um einen Vertrag, eine Norm, eine Spezifikation oder ein anderes formal vorgeschriebenes Dokument zu erfüllen.</li><li>Eine dokumentierte Darstellung einer Bedingung oder Fähigkeit wie in (1) oder (2).</li></ol><p>Anmerkung: Die obige Definition ist die klassische Definition aus IEEE Std 610.12 von 1990. Alternativ geben wir auch eine modernere Definition an:</p><ol><li>Ein von einem Stakeholder wahrgenommener Bedarf.</li><li>Eine Fähigkeit oder Eigenschaft, die ein System haben soll.</li><li>Eine dokumentierte Darstellung eines Bedarfs, einer Fähigkeit oder Eigenschaft.</li></ol>"@de ,
		"<p>Une 'Exigence' est un besoin physique et fonctionnel unique et documenté qu'une conception, un produit ou un processus particulier doit pouvoir satisfaire. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Définition:</p><ol><li>Condition ou capacité dont un utilisateur a besoin pour résoudre un problème ou atteindre un objectif.</li><li>Condition ou capacité qui doit être remplie ou possédée par un système ou un composant de système pour satisfaire à un contrat, à une norme, à une spécification ou à d'autres documents imposés officiellement.</li><li>Une représentation documentée d'une condition ou d'une capacité comme dans (1) ou (2).</li></ol><p>Remarque: La définition ci-dessus est la définition classique de la norme IEEE 610.12 de 1990. Nous donnons également une définition plus moderne:</p><ol><li>Un besoin perçu par une partie prenante;</li><li>Une capacité ou une propriété qu'un système doit avoir.</li><li>Une représentation documentée d'un besoin, d'une capacité ou d'une propriété.</li></ol>"@fr ;
	cas:Icon "&#8623;" .

casShapes_IREB:Requirement
	rdf:type sh:NodeShape ;
	sh:targetClass IREB:Requirement ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_SpecIF:Priority .

o:RC-Paragraph-10900558082
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "SpecIF:Paragraph" ;
	skos:definition "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

o:RC-Paragraph-10900558082_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-Paragraph-10900558082 ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
