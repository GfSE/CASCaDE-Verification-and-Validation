
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix FMC: <http://fmc-modeling.org#> .
@prefix IREB: <https://cpre.ireb.org/en/downloads-and-resources/glossary#> .
@prefix ReqIF: <https://www.prostep.org/fileadmin/downloads/PSI_ImplementationGuide_ReqIF_V1-7.pdf#> .
@prefix oslc_rm: <http://open-services.net/ns/rm#> .
@prefix pig: <https://product-information-graph.org/v0.2/metamodel#> .
@prefix SpecIF: <https://specif.de/v1.2/schema#> .
@prefix pigShapes_rdfs: <https://product-information-graph.org/v0.2/ontology/shapes/rdfs#> .
@prefix pigShapes_FMC: <https://product-information-graph.org/v0.2/ontology/shapes/FMC#> .
@prefix pigShapes_IREB: <https://product-information-graph.org/v0.2/ontology/shapes/IREB#> .
@prefix pigShapes_oslc_rm: <https://product-information-graph.org/v0.2/ontology/shapes/oslc_rm#> .
@prefix pigShapes_ReqIF: <https://product-information-graph.org/v0.2/ontology/shapes/ReqIF#> .
@prefix pigShapes_SpecIF: <https://product-information-graph.org/v0.2/ontology/shapes/SpecIF#> .
@prefix pigShapes_pig: <https://product-information-graph.org/v0.2/ontology/shapes/pig#> .

@prefix o: <https://product-information-graph.org/v0.2/ontology#> .
@prefix d: <https://product-information-graph.org/examples/09_Very-Simple-Model-FMC-with-Requirements.specif.zip#> .

#################################################################
# Project Metadata
#################################################################

d:
	rdf:type owl:Ontology ;
	rdfs:label "Project 'Very Simple Model (FMC) with Requirements'" ;
	owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ,
		<http://www.w3.org/2000/01/rdf-schema#> ;
	dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
	dcterms:modified "2026-03-06T17:36:25.471Z" .

#################################################################
# PIG Metamodel (pig:)
#################################################################

pig:Entity
	rdf:type owl:Class ;
	rdfs:label "Entity" ;
	rdfs:comment "A PIG meta-model item used for entities (aka resources or artifacts)." .

pigShapes_pig:Entity
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Entity ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:Category ,
		pigShapes_pig:Icon .

pig:Package
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Package" ;
	rdfs:comment "A PIG meta-model item used for packages comprising entities, relationships and potentially nested packages." .

pigShapes_pig:Package
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Package ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

pig:ModelElement
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Model-Element" ;
	rdfs:comment "The most generic class for all model elements (entities and relationships)." .

pigShapes_pig:ModelElement
	rdf:type sh:NodeShape ;
	sh:targetClass pig:ModelElement ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

FMC:Actor
	rdfs:subClassOf pig:ModelElement ;
	rdfs:label "Actor" ;
	rdfs:comment "A fundamental model-element class for actors (e.g. users, functions, systems, components, ...)." .

pigShapes_FMC:Actor
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Actor ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

FMC:State
	rdfs:subClassOf pig:ModelElement ;
	rdfs:label "State" ;
	rdfs:comment "A fundamental model-element class for states (e.g. system or process states, information, form, color, ...)." .

pigShapes_FMC:State
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:State ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

FMC:Event
	rdfs:subClassOf pig:ModelElement ;
	rdfs:label "Event" ;
	rdfs:comment "A fundamental model-element class for events (e.g. environmental or process events, ...)." .

pigShapes_FMC:Event
	rdf:type sh:NodeShape ;
	sh:targetClass FMC:Event ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

pig:Organizer
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Organizer" ;
	rdfs:comment "A class for organizing model-elements. An example is a list of requirements or a diagram using a certain notation." .

pigShapes_pig:Organizer
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Organizer ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

pig:Root
	rdfs:subClassOf pig:Organizer ;
	rdfs:label "Root" ;
	rdfs:comment "A subclass of pig:Organizer serving as a root for trees and tables." .

pigShapes_pig:Root
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Root ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:lists .

pig:Tree
	rdfs:subClassOf pig:Organizer ;
	rdfs:label "Tree" ;
	rdfs:comment "A subclass of pig:Organizer for strictly hierarchical data structures referencing entities and relationships." .

pigShapes_pig:Tree
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Tree ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:lists .

pig:Outline
	rdfs:subClassOf pig:Tree ;
	rdfs:label "Outline" ;
	rdfs:comment "A subclass of pig:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

pigShapes_pig:Outline
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Outline ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

pig:View
	rdfs:subClassOf pig:Organizer ;
	rdfs:label "View" ;
	rdfs:comment "A subclass of pig:Organizer representing a model view (diagram) using a certain notation showing selected model elements." .

pigShapes_pig:View
	rdf:type sh:NodeShape ;
	sh:targetClass pig:View ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:Diagram ,
		pigShapes_pig:Notation ,
		pigShapes_pig:shows ,
		pigShapes_pig:depicts .

pig:Table
	rdfs:subClassOf pig:Organizer ;
	rdfs:label "Table" ;
	rdfs:comment "A subclass of pig:Organizer representing a table showing selected model elements." .

pigShapes_pig:Table
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Table ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:shows .

pig:Enumeration
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Enumeration" ;
	rdfs:comment "A PIG meta-model item used for enumerations of values." .

pigShapes_pig:Enumeration
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Enumeration ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment .

pig:Relationship
	rdf:type owl:Class ;
	rdfs:label "Relationship" ;
	rdfs:comment "A PIG meta-model item used for reified relationships (aka predicates)." .

pigShapes_pig:Relationship
	rdf:type sh:NodeShape ;
	sh:targetClass pig:Relationship ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:Category ,
		pigShapes_pig:Icon ,
		pigShapes_pig:SourceLink ,
		pigShapes_pig:TargetLink .

pig:Property
	rdf:type owl:DatatypeProperty ;
	rdfs:label "Property" ;
	rdfs:comment "A PIG meta-model item used for properties (aka attributes)." .

pigShapes_pig:Property
	rdf:type sh:PropertyShape ;
	sh:path pig:Property ;
	sh:datatype xs:anyType .

pig:Icon
	rdfs:subPropertyOf pig:Property ;
	rdfs:label "has icon" ;
	rdfs:comment "Specifies an icon for a model element (entity or relationship)." .

pigShapes_pig:Icon
	rdf:type sh:PropertyShape ;
	sh:path pig:Icon ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

pig:Diagram
	rdfs:subPropertyOf pig:Property ;
	rdfs:label "Diagram" ;
	rdfs:comment "A diagram illustrating the resource or a link to a diagram." .

pigShapes_pig:Diagram
	rdf:type sh:PropertyShape ;
	sh:path pig:Diagram ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

pig:Category
	rdfs:subPropertyOf pig:Property ;
	rdfs:label "has category" ;
	rdfs:comment "Specifies a category for an element (entity, relationship or organizer)." .

pigShapes_pig:Category
	rdf:type sh:PropertyShape ;
	sh:path pig:Category ;
	sh:datatype xs:string ;
	sh:maxLength "32" ;
	sh:minCount "0" ;
	sh:maxCount "1" .

pig:Notation
	rdfs:subPropertyOf pig:Category ;
	rdfs:label "Notation" ;
	rdfs:comment "A reference to a notation defining the syntax and semantics of a diagram." .

pigShapes_pig:Notation
	rdf:type sh:PropertyShape ;
	sh:path pig:Notation ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

pig:Link
	rdf:type owl:ObjectProperty ;
	rdfs:range [ owl:unionOf(
			pig:Entity
			pig:Relationship
		)] ;
	rdfs:label "linked with" ;
	rdfs:comment "A PIG meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element." .

pigShapes_pig:Link
	rdf:type sh:PropertyShape ;
	sh:path pig:Link ;
	sh:or (
			[ sh:class pig:Entity ]
			[ sh:class pig:Relationship ]
		) .

pig:SourceLink
	rdfs:subPropertyOf pig:Link ;
	rdfs:range [ owl:unionOf(
			pig:Entity
			pig:Relationship
		)] ;
	rdfs:label "to source" ;
	rdfs:comment "Connects the source of a reified relationship." .

pigShapes_pig:SourceLink
	rdf:type sh:PropertyShape ;
	sh:path pig:SourceLink ;
	sh:or (
			[ sh:class pig:Entity ]
			[ sh:class pig:Relationship ]
		) .

pig:TargetLink
	rdfs:subPropertyOf pig:Link ;
	rdfs:range [ owl:unionOf(
			pig:Entity
			pig:Relationship
		)] ;
	rdfs:label "to target" ;
	rdfs:comment "Connects the target of a reified relationship or an organizer." .

pigShapes_pig:TargetLink
	rdf:type sh:PropertyShape ;
	sh:path pig:TargetLink ;
	sh:or (
			[ sh:class pig:Entity ]
			[ sh:class pig:Relationship ]
		) .

pig:lists
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:range [ owl:unionOf(
			pig:Entity
			pig:Relationship
			pig:Organizer
		)] ;
	rdfs:label "lists" ;
	rdfs:comment "Lists an entity, a relationship or a subordinated organizer." .

pigShapes_pig:lists
	rdf:type sh:PropertyShape ;
	sh:path pig:lists ;
	sh:or (
			[ sh:class pig:Entity ]
			[ sh:class pig:Relationship ]
			[ sh:class pig:Organizer ]
		) .

pig:shows
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:range [ owl:unionOf(
			pig:Entity
			pig:Relationship
		)] ;
	rdfs:label "shows" ;
	rdfs:comment "Shows an entity or a relationship." .

pigShapes_pig:shows
	rdf:type sh:PropertyShape ;
	sh:path pig:shows ;
	sh:or (
			[ sh:class pig:Entity ]
			[ sh:class pig:Relationship ]
		) .

pig:depicts
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:range pig:Entity ;
	rdfs:label "depicts" ;
	rdfs:comment "Depicts an entity; inverse of uml:ownedDiagram." .

pigShapes_pig:depicts
	rdf:type sh:PropertyShape ;
	sh:path pig:depicts ;
	sh:or (
			[ sh:class pig:Entity ]
		) .

#################################################################
# Data Types with Enumerated Values
#################################################################

SpecIF:Priority-Value
	rdfs:subClassOf pig:Enumeration ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	rdfs:comment "Enumerated values for the 'Priority' of the resource."@en ;
	owl:oneOf (
			SpecIF:priorityHigh
			SpecIF:priorityMedium
			SpecIF:priorityLow
		) .
SpecIF:priorityHigh
	rdf:type SpecIF:Priority-Value ;
	rdfs:label "high"@en ,
		"hoch"@de ,
		"haut"@fr .
SpecIF:priorityMedium
	rdf:type SpecIF:Priority-Value ;
	rdfs:label "medium"@en ,
		"mittel"@de ,
		"moyen"@fr .
SpecIF:priorityLow
	rdf:type SpecIF:Priority-Value ;
	rdfs:label "low"@en ,
		"niedrig"@de ,
		"bas"@fr .

#################################################################
# Ontology - Property Classes
#################################################################

# Skipping implicit property: rdfs:label

# Skipping implicit property: rdfs:comment

# Skipping implicit property: pig:Diagram

# Skipping implicit property: pig:Category

SpecIF:Priority
	rdf:type owl:ObjectProperty ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	rdfs:comment "Enumerated values for the 'Priority' of the resource."@en ;
	rdfs:range SpecIF:Priority-Value .

pigShapes_SpecIF:Priority
	rdf:type sh:PropertyShape ;
	sh:path SpecIF:Priority ;
	sh:maxCount "1" ;
	sh:class SpecIF:Priority-Value .

o:PC-Diagram-10408483458
	rdf:type owl:DatatypeProperty ;
	rdfs:label "pig:Diagram" ;
	rdfs:comment "A diagram illustrating the resource or a link to a diagram." .

o:PC-Diagram-10408483458_shape
	rdf:type sh:PropertyShape ;
	sh:path o:PC-Diagram-10408483458 ;
	sh:datatype xs:string .

#################################################################
# Ontology - Entity Classes
#################################################################

SpecIF:Paragraph
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Paragraph"@en ,
		"Textabsatz"@de ,
		"Paragraphe"@fr ;
	rdfs:comment "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

pigShapes_SpecIF:Paragraph
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:Paragraph ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_pig:Diagram ,
		pigShapes_pig:Category .

IREB:Requirement
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Entity ;
	rdfs:label "Requirement"@en ,
		"Anforderung"@de ,
		"Exigence"@fr ;
	rdfs:comment "<p>A 'Requirement' is a singular documented physical and functional need that a particular design, product or process must be able to perform. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>A condition or capability needed by a user to solve a problem or achieve an objective.</li><li>A condition or capability that must be met or possessed by a system or system component to satisfy a contract, standard, specification, or other formally imposed documents.</li><li>A documented representation of a condition or capability as in (1) or (2).</li></ol><p>Note: The definition above is the classic one from IEEE Std 610.12 of 1990. Alternatively, we also give a more modern definition:</p><ol><li>A need perceived by a stakeholder.</li><li>A capability or property that a system shall have.</li><li>A documented representation of a need, capability or property.</li></ol>"@en ,
		"<p>Eine 'Anforderung' ist ein einzelnes dokumentiertes physisches und funktionales Bedürfnis, das ein bestimmter Entwurf, ein Produkt oder ein Prozess erfüllen muss. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>Eine Bedingung oder Fähigkeit, die ein Benutzer benötigt, um ein Problem zu lösen oder ein Ziel zu erreichen.</li><li>Eine Bedingung oder Fähigkeit, die ein System oder eine Systemkomponente erfüllen oder besitzen muss, um einen Vertrag, eine Norm, eine Spezifikation oder ein anderes formal vorgeschriebenes Dokument zu erfüllen.</li><li>Eine dokumentierte Darstellung einer Bedingung oder Fähigkeit wie in (1) oder (2).</li></ol><p>Anmerkung: Die obige Definition ist die klassische Definition aus IEEE Std 610.12 von 1990. Alternativ geben wir auch eine modernere Definition an:</p><ol><li>Ein von einem Stakeholder wahrgenommener Bedarf.</li><li>Eine Fähigkeit oder Eigenschaft, die ein System haben soll.</li><li>Eine dokumentierte Darstellung eines Bedarfs, einer Fähigkeit oder Eigenschaft.</li></ol>"@de ,
		"<p>Une 'Exigence' est un besoin physique et fonctionnel unique et documenté qu'une conception, un produit ou un processus particulier doit pouvoir satisfaire. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Définition:</p><ol><li>Condition ou capacité dont un utilisateur a besoin pour résoudre un problème ou atteindre un objectif.</li><li>Condition ou capacité qui doit être remplie ou possédée par un système ou un composant de système pour satisfaire à un contrat, à une norme, à une spécification ou à d'autres documents imposés officiellement.</li><li>Une représentation documentée d'une condition ou d'une capacité comme dans (1) ou (2).</li></ol><p>Remarque: La définition ci-dessus est la définition classique de la norme IEEE 610.12 de 1990. Nous donnons également une définition plus moderne:</p><ol><li>Un besoin perçu par une partie prenante;</li><li>Une capacité ou une propriété qu'un système doit avoir.</li><li>Une représentation documentée d'un besoin, d'une capacité ou d'une propriété.</li></ol>"@fr ;
	pig:Icon "&#8623;" .

pigShapes_IREB:Requirement
	rdf:type sh:NodeShape ;
	sh:targetClass IREB:Requirement ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		pigShapes_SpecIF:Priority .

o:RC-Paragraph-10408483458
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Entity ;
	rdfs:label "SpecIF:Paragraph" ;
	rdfs:comment "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

o:RC-Paragraph-10408483458_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-Paragraph-10408483458 ;
	sh:property pigShapes_rdfs:label ,
		pigShapes_rdfs:comment ,
		o:PC-Diagram-10408483458_shape ,
		pigShapes_pig:Category .

#################################################################
# Ontology - Relationship Classes
#################################################################

SpecIF:writes
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Relationship ;
	rdfs:label "writes"@en ,
		"schreibt"@de ,
		"écrit"@fr ;
	rdfs:comment "A [[FMC:Actor]] 'writes' (changes) a [[FMC:State]]."@en .

SpecIF:writes-toSource
	rdfs:subPropertyOf pig:SourceLink ;
	rdfs:label "SpecIF:writes to source" ;
	rdfs:comment "Connects the source of SpecIF:writes" ;
	rdfs:domain SpecIF:writes ;
	rdfs:range FMC:Actor .

SpecIF:writes-toTarget
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:label "SpecIF:writes to target" ;
	rdfs:comment "Connects the target of SpecIF:writes" ;
	rdfs:domain SpecIF:writes ;
	rdfs:range FMC:State .

pigShapes_SpecIF:writes
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:writes ;
	sh:property pigShapes_rdfs:comment ;
	sh:property [ 
		sh:path SpecIF:writes-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path SpecIF:writes-toTarget ;
		sh:or (
			[ sh:class FMC:State ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

SpecIF:reads
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Relationship ;
	rdfs:label "reads"@en ,
		"liest"@de ,
		"lit"@fr ;
	rdfs:comment "A [[FMC:Actor]] 'reads' a [[FMC:State]]."@en .

SpecIF:reads-toSource
	rdfs:subPropertyOf pig:SourceLink ;
	rdfs:label "SpecIF:reads to source" ;
	rdfs:comment "Connects the source of SpecIF:reads" ;
	rdfs:domain SpecIF:reads ;
	rdfs:range FMC:Actor .

SpecIF:reads-toTarget
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:label "SpecIF:reads to target" ;
	rdfs:comment "Connects the target of SpecIF:reads" ;
	rdfs:domain SpecIF:reads ;
	rdfs:range FMC:State .

pigShapes_SpecIF:reads
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:reads ;
	sh:property pigShapes_rdfs:comment ;
	sh:property [ 
		sh:path SpecIF:reads-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path SpecIF:reads-toTarget ;
		sh:or (
			[ sh:class FMC:State ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

oslc_rm:satisfies
	rdf:type owl:Class ;
	rdfs:subClassOf pig:Relationship ;
	rdfs:label "satisfies"@en ,
		"erfüllt"@de ,
		"satisfait"@fr ;
	rdfs:comment "<p>The object is satisfied by the subject. <small>(<i>source: <a href=\"http://open-services.net/\">OSLC</a></i>)</small></p><p>SpecIF suggests that the subject is confined to a model element, e.g, a [[FMC:Actor]] or [[FMC:State]], and the object is confined to a [[IREB:Requirement]]. More concretely, an example for this type of statement is 'Component-X <em>satisfies</em> 'Requirement-4711'.</p>"@en .

oslc_rm:satisfies-toSource
	rdfs:subPropertyOf pig:SourceLink ;
	rdfs:label "oslc_rm:satisfies to source" ;
	rdfs:comment "Connects the source of oslc_rm:satisfies" ;
	rdfs:domain oslc_rm:satisfies ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
		)] .

oslc_rm:satisfies-toTarget
	rdfs:subPropertyOf pig:TargetLink ;
	rdfs:label "oslc_rm:satisfies to target" ;
	rdfs:comment "Connects the target of oslc_rm:satisfies" ;
	rdfs:domain oslc_rm:satisfies ;
	rdfs:range IREB:Requirement .

pigShapes_oslc_rm:satisfies
	rdf:type sh:NodeShape ;
	sh:targetClass oslc_rm:satisfies ;
	sh:property pigShapes_rdfs:comment ;
	sh:property [ 
		sh:path oslc_rm:satisfies-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path oslc_rm:satisfies-toTarget ;
		sh:or (
			[ sh:class IREB:Requirement ]
		) ;
