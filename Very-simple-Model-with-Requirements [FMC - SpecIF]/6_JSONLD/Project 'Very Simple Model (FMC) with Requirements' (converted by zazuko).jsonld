    {
      "@id": "d:Req-0Z7916e2872e78ecadc50feddc00918a",
      "@type": "IREB:Requirement",
      "dcterms:modified": "2020-10-17T10:00:00+01:00",
      "rdfs:comment": "<p>The data store MUST be consistent at all times.</p>",
      "rdfs:label": "Consistency",
      "SpecIF:Priority": {
        "@id": "SpecIF:priorityHigh"
      }
    },
    {
      "@id": "d:Req-1a8016e2872e78ecadc50feddc00029b",
      "@type": "IREB:Requirement",
