    {
      "@id": "oslc_rm:satisfies",
      "rdf:type": {
        "@id": "owl:Class"
      },
      "rdfs:subClassOf": {
        "@id": "pig:Relationship"
      },
      "rdfs:label": [
        {
          "@value": "satisfies",
          "@language": "en"
        },
        {
          "@value": "erfüllt",
          "@language": "de"
        },
        {
          "@value": "satisfait",
          "@language": "fr"
        }
      ],
      "rdfs:comment": {
        "@value": "<p>The object is satisfied by the subject. <small>(<i>source: <a href=\"http://open-services.net/\">OSLC</a></i>)</small></p><p>SpecIF suggests that the subject is confined to a model element, e.g, a [[FMC:Actor]] or [[FMC:State]], and the object is confined to a [[IREB:Requirement]]. More concretely, an example for this type of statement is 'Component-X <em>satisfies</em> 'Requirement-4711'.</p>",
        "@language": "en"
      }
    },
    {
      "@id": "oslc_rm:satisfies-toSource",
      "rdfs:subPropertyOf": {
        "@id": "pig:SourceLink"
      },
      "rdfs:label": "oslc_rm:satisfies to source",
      "rdfs:comment": "Connects the source of oslc_rm:satisfies",
      "rdfs:domain": {
        "@id": "oslc_rm:satisfies"
      },
      "rdfs:range": {
        "owl:unionOf": {
          "@list": [
            {
              "@id": "FMC:Actor"
            },
            {
              "@id": "FMC:State"
            }
          ]
        }
      }
    },
    {
      "@id": "oslc_rm:satisfies-toTarget",
      "rdfs:subPropertyOf": {
        "@id": "pig:TargetLink"
      },
      "rdfs:label": "oslc_rm:satisfies to target",
      "rdfs:comment": "Connects the target of oslc_rm:satisfies",
      "rdfs:domain": {
        "@id": "oslc_rm:satisfies"
      },
      "rdfs:range": {
        "@id": "IREB:Requirement"
      }
    },
