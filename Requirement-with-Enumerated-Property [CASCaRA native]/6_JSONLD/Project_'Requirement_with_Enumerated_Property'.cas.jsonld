      "dcterms:title": [
        {
          "@value": "Minimum button size",
          "@language": "en"
        }
      ],
      "dcterms:description": [
        {
          "@value": "<p>The <i>button size</i> MUST not be less than 20mm in diameter.</p>",
          "@language": "en"
        }
      ],
