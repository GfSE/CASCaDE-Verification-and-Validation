
@prefix o: <https://product-information-graph.org/v0.2/ontology#> .
@prefix d: <https://product-information-graph.org/examples/05_Requirement-with-Enumerated-Property.specif#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <https://www.w3.org/TR/skos-reference/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix FMC: <http://fmc-modeling.org#> .
@prefix IREB: <https://cpre.ireb.org/en/downloads-and-resources/glossary#> .
@prefix cas: <https://product-information-graph.org/v0.2/metamodel#> .
@prefix SpecIF: <https://specif.de/v1.2/schema#> .

d:P-Requirement-with-Enumerated-Property
	a cas:Package ;
	rdfs:label "Project 'Requirement with Enumerated Property'" ;
	dcterms:modified "2026-05-14T08:33:28.561Z"^^xs:dateTime .

#################################################################
# Graph Items
#################################################################

cas:Organizer
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer" ;
	skos:definition "A CASCaRA meta-model item for organizing model-elements. An example is a list of requirements or a diagram using a certain notation." .

cas:Organizer_shape
	a sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) .

cas:Package
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Package" ;
	skos:definition "A subclass of cas:Organizer used for a partial graph selected for exchange or access permissions." .

cas:Package_shape
	a sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) .

cas:Root
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Root" ;
	skos:definition "A subclass of cas:Organizer serving as a root for trees and tables." .

cas:Root_shape
	a sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:lists_shape .

cas:Tree
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Tree" ;
	skos:definition "A subclass of cas:Organizer for strictly hierarchical data structures referencing entities and relationships." .

cas:Tree_shape
	a sh:NodeShape ;
	sh:targetClass cas:Tree ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:lists_shape .

cas:Outline
	rdfs:subClassOf cas:Tree ;
	rdfs:label "Outline" ;
	skos:definition "A subclass of cas:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

cas:Outline_shape
	a sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) .

cas:Diagram
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

cas:Diagram_shape
	a sh:PropertyShape ;
	sh:path cas:Diagram ;
	sh:datatype xs:string ;
	sh:minCount 0 .

cas:Category
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category" ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)." .

cas:Category_shape
	a sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 ;
	sh:maxLength 32 .

cas:Notation
	rdfs:subPropertyOf cas:Category ;
	rdfs:label "Notation" ;
	skos:definition "A reference to a notation defining the syntax and semantics of a diagram." .

cas:Notation_shape
	a sh:PropertyShape ;
	sh:path cas:Notation ;
	sh:datatype xs:string ;
	sh:minCount 0 ;
	sh:maxCount 1 .

cas:linksSource
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to source" ;
	skos:definition "Connects the source of a reified relationship." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksSource_shape
	a sh:PropertyShape ;
	sh:path cas:linksSource ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:linksTarget
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "to target" ;
	skos:definition "Connects the target of a reified relationship or an organizer." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship ) ] .

cas:linksTarget_shape
	a sh:PropertyShape ;
	sh:path cas:linksTarget ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] ) .

cas:lists
	rdfs:subPropertyOf cas:linksTarget ;
	rdfs:label "lists" ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer." ;
	rdfs:range [ owl:unionOf ( cas:Entity cas:Relationship cas:Organizer ) ] .

cas:lists_shape
	a sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or ( [ sh:class cas:Entity ] [ sh:class cas:Relationship ] [ sh:class cas:Organizer ] ) .

SpecIF:Priority-Enumeration
	rdfs:subClassOf cas:Enumeration ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	cas:enumeratedValue SpecIF:priorityHigh ,
		SpecIF:priorityRatherHigh ,
		SpecIF:priorityMedium ,
		SpecIF:priorityRatherLow ,
		SpecIF:priorityLow .

SpecIF:Priority
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	rdfs:range SpecIF:Priority-Enumeration .

SpecIF:Priority_shape
	a sh:PropertyShape ;
	sh:path SpecIF:Priority ;
	sh:class SpecIF:Priority-Enumeration .

IREB:Requirement
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Requirement"@en ,
		"Anforderung"@de ,
		"Exigence"@fr ;
	skos:definition "<p>A 'Requirement' is a singular documented physical and functional need that a particular design, product or process must be able to perform. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>A condition or capability needed by a user to solve a problem or achieve an objective.</li><li>A condition or capability that must be met or possessed by a system or system component to satisfy a contract, standard, specification, or other formally imposed documents.</li><li>A documented representation of a condition or capability as in (1) or (2).</li></ol><p>Note: The definition above is the classic one from IEEE Std 610.12 of 1990. Alternatively, we also give a more modern definition:</p><ol><li>A need perceived by a stakeholder.</li><li>A capability or property that a system shall have.</li><li>A documented representation of a need, capability or property.</li></ol>"@en ,
		"<p>Eine 'Anforderung' ist ein einzelnes dokumentiertes physisches und funktionales Bedürfnis, das ein bestimmter Entwurf, ein Produkt oder ein Prozess erfüllen muss. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>Eine Bedingung oder Fähigkeit, die ein Benutzer benötigt, um ein Problem zu lösen oder ein Ziel zu erreichen.</li><li>Eine Bedingung oder Fähigkeit, die ein System oder eine Systemkomponente erfüllen oder besitzen muss, um einen Vertrag, eine Norm, eine Spezifikation oder ein anderes formal vorgeschriebenes Dokument zu erfüllen.</li><li>Eine dokumentierte Darstellung einer Bedingung oder Fähigkeit wie in (1) oder (2).</li></ol><p>Anmerkung: Die obige Definition ist die klassische Definition aus IEEE Std 610.12 von 1990. Alternativ geben wir auch eine modernere Definition an:</p><ol><li>Ein von einem Stakeholder wahrgenommener Bedarf.</li><li>Eine Fähigkeit oder Eigenschaft, die ein System haben soll.</li><li>Eine dokumentierte Darstellung eines Bedarfs, einer Fähigkeit oder Eigenschaft.</li></ol>"@de ,
		"<p>Une 'Exigence' est un besoin physique et fonctionnel unique et documenté qu'une conception, un produit ou un processus particulier doit pouvoir satisfaire. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Définition:</p><ol><li>Condition ou capacité dont un utilisateur a besoin pour résoudre un problème ou atteindre un objectif.</li><li>Condition ou capacité qui doit être remplie ou possédée par un système ou un composant de système pour satisfaire à un contrat, à une norme, à une spécification ou à d'autres documents imposés officiellement.</li><li>Une représentation documentée d'une condition ou d'une capacité comme dans (1) ou (2).</li></ol><p>Remarque: La définition ci-dessus est la définition classique de la norme IEEE 610.12 de 1990. Nous donnons également une définition plus moderne:</p><ol><li>Un besoin perçu par une partie prenante;</li><li>Une capacité ou une propriété qu'un système doit avoir.</li><li>Une représentation documentée d'un besoin, d'une capacité ou d'une propriété.</li></ol>"@fr ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	cas:icon "\"&#8623;\"" .

IREB:Requirement_shape
	a sh:NodeShape ;
	sh:targetClass IREB:Requirement ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property SpecIF:Priority_shape .

SpecIF:Paragraph
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Paragraph"@en ,
		"Textabsatz"@de ,
		"Paragraphe"@fr ;
	skos:definition "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de ;
	cas:revision "1.1" ;
	dcterms:modified "2024-03-02T20:55:23.295Z"^^xs:dateTime .

SpecIF:Paragraph_shape
	a sh:NodeShape ;
	sh:targetClass SpecIF:Paragraph ;
	sh:or ( [ sh:path rdfs:label ; sh:minCount 1 ] [ sh:path rdfs:comment ; sh:minCount 1 ] ) ;
	sh:property cas:Diagram_shape ;
	sh:property cas:Category_shape .

d:Req-35100bca2b005ba
	a IREB:Requirement ;
	rdfs:label "Minimum button size"@en ;
	rdfs:comment "<p>The <i>button size</i> MUST not be less than 20mm in diameter.</p>"@en ;
	dcterms:modified "2020-03-26T22:59:00+02:00"^^xs:dateTime ;
	SpecIF:Priority SpecIF:priorityRatherHigh .

d:HierarchyRoot-P-Requirement-with-Enumerated-Property
	a cas:Root ;
	rdfs:label "Hierarchy Root" ;
	rdfs:comment "... anchoring all hierarchies of this graph (package)" ;
	dcterms:modified "2026-05-14T08:33:28.683Z"^^xs:dateTime ;
	cas:lists d:HR-bca801377e3d1547 .

d:HR-bca801377e3d1547
	a cas:Outline ;
	rdfs:label "Project 'Requirement with Enumerated Property'" ;
	dcterms:modified "2026-05-14T08:33:28.620Z"^^xs:dateTime ;
	cas:Category ReqIF:HierarchyRoot ;
	cas:lists d:Req-35100bca2b005ba .


#################################################################
# Metamodel Class Shapes
#################################################################

cas:Property_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:DatatypeProperty ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:DatatypeProperty ] [ sh:path rdfs:subPropertyOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path sh:defaultValue ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:composes ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Property_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:DatatypeProperty ;
	sh:sparql [
		sh:message "Property class must have a corresponding PropertyShape with at least sh:datatype defined" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:PropertyShape ;
						sh:path $this ;
						sh:datatype ?dt .
				}
			}
		"""
	] .

cas:Link_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:ObjectProperty ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:ObjectProperty ] [ sh:path rdfs:subPropertyOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:range ; sh:minCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Link_shape_requirement_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subPropertyOf ;
	sh:targetClass owl:ObjectProperty ;
	sh:sparql [
		sh:message "Link class must have a corresponding PropertyShape with at least sh:class or sh:or constraint defined" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:PropertyShape ;
						sh:path $this .
					FILTER ( EXISTS { ?shape sh:class ?c } || EXISTS { ?shape sh:or ?o } )
				}
			}
		"""
	] .

cas:Enumeration_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass owl:Class ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:enumeratedValue ; sh:minCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Enumeration_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass owl:Class ;
	sh:sparql [
		sh:message "Enumeration class must have at least one valid enumeratedValue" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					$this cas:enumeratedValue ?value .
				}
			}
		"""
	] .

cas:Entity_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Entity ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:icon ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Entity_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Entity ;
	sh:sparql [
		sh:message "Entity class should have a corresponding NodeShape with sh:targetClass constraint" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Entity shape should have sh:property for each enumeratedProperty defined in the class" ;
		sh:select """
			SELECT $this ?prop
			WHERE {
				$this cas:enumeratedProperty ?prop .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?propShape .
					?propShape sh:path ?prop .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Entity shape should have sh:property for each enumeratedTargetLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedTargetLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] .

cas:Relationship_class_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Relationship ;
	sh:closed "true" ;
	sh:ignoredProperties ( rdf:type ) ;
	sh:or ( [ sh:path rdf:type ; sh:hasValue owl:Class ] [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ) ;
	sh:property [ sh:path rdfs:label ; sh:minCount 1 ; sh:maxCount 1 ] ;
	sh:property [ sh:path rdfs:comment ; sh:maxCount 1 ] ;
	sh:property [ sh:path skos:definition ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:revision ; sh:maxCount 1 ; sh:datatype xs:string ] ;
	sh:property [ sh:path cas:priorRevision ] ;
	sh:property [ sh:path dcterms:modified ; sh:maxCount 1 ; sh:datatype xs:dateTime ] ;
	sh:property [ sh:path dcterms:creator ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:icon ; sh:maxCount 1 ] ;
	sh:property [ sh:path cas:itemType ; sh:maxCount 1 ] .

cas:Relationship_shape_shape
	a sh:NodeShape ;
	sh:targetSubjectsOf rdfs:subClassOf ;
	sh:targetClass cas:Relationship ;
	sh:sparql [
		sh:message "Relationship class should have a corresponding NodeShape with sh:targetClass constraint" ;
		sh:select """
			SELECT $this
			WHERE {
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedProperty defined in the class" ;
		sh:select """
			SELECT $this ?prop
			WHERE {
				$this cas:enumeratedProperty ?prop .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?propShape .
					?propShape sh:path ?prop .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedSourceLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedSourceLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] ;
	sh:sparql [
		sh:message "Relationship shape should have sh:property for each enumeratedTargetLink defined in the class" ;
		sh:select """
			SELECT $this ?link
			WHERE {
				$this cas:enumeratedTargetLink ?link .
				FILTER NOT EXISTS {
					?shape a sh:NodeShape ;
						sh:targetClass $this ;
						sh:property ?linkShape .
					?linkShape sh:path ?link .
				}
			}
		"""
	] .

