{"@context":{"o":"https://product-information-graph.org/v0.2/ontology#","d":"https://product-information-graph.org/examples/Small%20Autonomous%20Vehicle.specif.zip#","rdf":"http://www.w3.org/1999/02/22-rdf-syntax-ns#","rdfs":"http://www.w3.org/2000/01/rdf-schema#","owl":"http://www.w3.org/2002/07/owl#","skos":"https://www.w3.org/TR/skos-reference/","sh":"http://www.w3.org/ns/shacl#","xs":"http://www.w3.org/2001/XMLSchema#","dcterms":"http://purl.org/dc/terms/","FMC":"http://fmc-modeling.org#","RFLP":"https://product-information-graph.org/v0.2/ontology/RFLP#","IREB":"https://cpre.ireb.org/en/downloads-and-resources/glossary#","oslc_rm":"http://open-services.net/ns/rm#","uml":"https://www.omg.org/spec/UML#","sysml":"https://www.omg.org/spec/SysML#","cas":"https://product-information-graph.org/v0.2/metamodel#","SpecIF":"https://specif.de/v1.2/schema#"},"@id":"d:P-eee_1045467100313_135436_1","@type":"cas:Package","dcterms:title":[{"@value":"Small Autonomous Vehicle"}],"dcterms:description":[{"@value":"A set of SpecIF Classes derived from a SpecIF Ontology for the domains SpecIF:DomainBase, SpecIF:DomainSystemsEngineering, SpecIF:DomainSystemModelIntegration.","@language":"en"}],"dcterms:modified":"2026-04-08T09:48:37.989Z","@graph":[{"@id":"cas:Entity","@type":"owl:Class","cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Entity"}],"skos:definition":[{"@value":"A CASCaRA meta-model item used for entities (aka resources or artifacts)."}],"cas:enumeratedProperty":[{"@id":"cas:Category"},{"@id":"cas:Icon"}]},{"@id":"cas:Package","@type":"owl:Class","cas:specializes":{"@id":"cas:Entity"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Package"}],"skos:definition":[{"@value":"A CASCaRA meta-model item used for packages comprising entities, relationships and potentially nested packages."}],"cas:enumeratedProperty":[]},{"@id":"cas:Artifact","@type":"owl:Class","cas:specializes":{"@id":"cas:Entity"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Artifact"}],"skos:definition":[{"@value":"The most generic class for all model entities (e.g. requirement, function, system, component, state, event, ...)."}],"cas:enumeratedProperty":[]},{"@id":"FMC:Actor","@type":"owl:Class","cas:specializes":{"@id":"cas:Artifact"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Actor"}],"skos:definition":[{"@value":"A fundamental model-element class for actors (e.g. users, functions, systems, components, ...)."}],"cas:enumeratedProperty":[]},{"@id":"FMC:State","@type":"owl:Class","cas:specializes":{"@id":"cas:Artifact"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"State"}],"skos:definition":[{"@value":"A fundamental model-element class for states (e.g. system or process states, information, form, color, ...)."}],"cas:enumeratedProperty":[]},{"@id":"FMC:Event","@type":"owl:Class","cas:specializes":{"@id":"cas:Artifact"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Event"}],"skos:definition":[{"@value":"A fundamental model-element class for events (e.g. environmental or process events, ...)."}],"cas:enumeratedProperty":[]},{"@id":"cas:Organizer","@type":"owl:Class","cas:specializes":{"@id":"cas:Entity"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Organizer"}],"skos:definition":[{"@value":"A class for organizing model-elements. An example is a list of requirements or a diagram using a certain notation."}],"cas:enumeratedProperty":[]},{"@id":"cas:Root","@type":"owl:Class","cas:specializes":{"@id":"cas:Organizer"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Root"}],"skos:definition":[{"@value":"A subclass of cas:Organizer serving as a root for trees and tables."}],"cas:enumeratedProperty":[],"cas:enumeratedTargetLink":[{"@id":"cas:lists"}]},{"@id":"cas:Tree","@type":"owl:Class","cas:specializes":{"@id":"cas:Organizer"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Tree"}],"skos:definition":[{"@value":"A subclass of cas:Organizer for strictly hierarchical data structures referencing entities and relationships."}],"cas:enumeratedProperty":[],"cas:enumeratedTargetLink":[{"@id":"cas:lists"}]},{"@id":"cas:Outline","@type":"owl:Class","cas:specializes":{"@id":"cas:Tree"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Outline"}],"skos:definition":[{"@value":"A subclass of cas:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized."}],"cas:enumeratedProperty":[]},{"@id":"cas:View","@type":"owl:Class","cas:specializes":{"@id":"cas:Organizer"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"View"}],"skos:definition":[{"@value":"A subclass of cas:Organizer representing a model view (diagram) using a certain notation showing selected model elements."}],"cas:enumeratedProperty":[{"@id":"cas:Diagram"},{"@id":"cas:Notation"}],"cas:enumeratedTargetLink":[{"@id":"cas:shows"},{"@id":"cas:depicts"}]},{"@id":"cas:Table","@type":"owl:Class","cas:specializes":{"@id":"cas:Organizer"},"cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Table"}],"skos:definition":[{"@value":"A subclass of cas:Organizer representing a table showing selected model elements."}],"cas:enumeratedProperty":[],"cas:enumeratedTargetLink":[{"@id":"cas:shows"}]},{"@id":"cas:Enumeration","@type":"owl:Class","cas:itemType":{"@id":"cas:Entity"},"dcterms:title":[{"@value":"Enumeration"}],"skos:definition":[{"@value":"A CASCaRA meta-model item used for enumerations of values."}],"cas:enumeratedProperty":[]},{"@id":"cas:Relationship","@type":"owl:Class","cas:itemType":{"@id":"cas:Relationship"},"dcterms:title":[{"@value":"Relationship"}],"skos:definition":[{"@value":"A CASCaRA meta-model item used for reified relationships (aka predicates)."}],"cas:enumeratedProperty":[{"@id":"cas:Category"},{"@id":"cas:Icon"}],"cas:enumeratedSourceLink":{"@id":"cas:SourceLink"},"cas:enumeratedTargetLink":{"@id":"cas:TargetLink"}},{"@id":"cas:Property","@type":"owl:DatatypeProperty","cas:itemType":{"@id":"cas:Property"},"dcterms:title":[{"@value":"Property"}],"skos:definition":[{"@value":"A CASCaRA meta-model item used for properties (aka attributes)."}],"sh:datatype":{"@id":"xs:anyType"}},{"@id":"cas:Icon","@type":"owl:DatatypeProperty","cas:specializes":{"@id":"cas:Property"},"cas:itemType":{"@id":"cas:Property"},"dcterms:title":[{"@value":"has icon"}],"skos:definition":[{"@value":"Specifies an icon for a model element (entity or relationship)."}],"sh:datatype":{"@id":"xs:string"},"sh:minCount":0,"sh:maxCount":1},{"@id":"cas:Diagram","@type":"owl:DatatypeProperty","cas:specializes":{"@id":"cas:Property"},"cas:itemType":{"@id":"cas:Property"},"dcterms:title":[{"@value":"Diagram"}],"skos:definition":[{"@value":"A diagram illustrating the resource or a link to a diagram."}],"sh:datatype":{"@id":"xs:string"},"sh:minCount":0},{"@id":"cas:Category","@type":"owl:DatatypeProperty","cas:specializes":{"@id":"cas:Property"},"cas:itemType":{"@id":"cas:Property"},"dcterms:title":[{"@value":"has category"}],"skos:definition":[{"@value":"Specifies a category for an element (entity, relationship or organizer)."}],"sh:datatype":{"@id":"xs:string"},"sh:maxLength":32,"sh:minCount":0,"sh:maxCount":1},{"@id":"cas:Notation","@type":"owl:DatatypeProperty","cas:specializes":{"@id":"cas:Category"},"cas:itemType":{"@id":"cas:Property"},"dcterms:title":[{"@value":"Notation"}],"skos:definition":[{"@value":"A reference to a notation defining the syntax and semantics of a diagram."}],"sh:datatype":{"@id":"xs:string"},"sh:minCount":0,"sh:maxCount":1},{"@id":"cas:Link","@type":"owl:ObjectProperty","cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}],"dcterms:title":[{"@value":"linked with"}],"skos:definition":[{"@value":"A PIG meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element."}]},{"@id":"cas:SourceLink","@type":"owl:ObjectProperty","cas:specializes":{"@id":"cas:Link"},"cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}],"dcterms:title":[{"@value":"to source"}],"skos:definition":[{"@value":"Connects the source of a reified relationship."}]},{"@id":"cas:TargetLink","@type":"owl:ObjectProperty","cas:specializes":{"@id":"cas:Link"},"cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}],"dcterms:title":[{"@value":"to target"}],"skos:definition":[{"@value":"Connects the target of a reified relationship or an organizer."}]},{"@id":"cas:lists","@type":"owl:ObjectProperty","cas:specializes":{"@id":"cas:TargetLink"},"cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"},{"@id":"cas:Organizer"}],"dcterms:title":[{"@value":"lists"}],"skos:definition":[{"@value":"Lists an entity, a relationship or a subordinated organizer."}]},{"@id":"cas:shows","@type":"owl:ObjectProperty","cas:specializes":{"@id":"cas:TargetLink"},"cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}],"dcterms:title":[{"@value":"shows"}],"skos:definition":[{"@value":"Shows an entity or a relationship."}]},{"@id":"cas:depicts","@type":"owl:ObjectProperty","cas:specializes":{"@id":"cas:TargetLink"},"cas:itemType":{"@id":"cas:Link"},"cas:enumeratedEndpoint":[{"@id":"cas:Entity"}],"dcterms:title":[{"@value":"depicts"}],"skos:definition":[{"@value":"Depicts an entity; inverse of uml:ownedDiagram."}]},{"@id":"o:PC-Diagram-9846713279","dcterms:title":[{"@value":"cas:Diagram"}],"skos:definition":[{"@value":"A diagram illustrating the resource or a link to a diagram."}],"cas:revision":"1.1","dcterms:modified":"2026-02-12T22:05:14.551Z","@type":"owl:DatatypeProperty","cas:specializes":{"@id":"cas:Property"},"cas:itemType":{"@id":"cas:Property"},"sh:datatype":{"@id":"xs:string"}},{"@id":"SpecIF:Paragraph","dcterms:title":[{"@value":"Paragraph","@language":"en"},{"@value":"Textabsatz","@language":"de"},{"@value":"Paragraphe","@language":"fr"}],"skos:definition":[{"@value":"<p>A 'Paragraph' is an unspecified information in a document at any level.</p>","@language":"en"},{"@value":"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>","@language":"de"}],"cas:revision":"1.1","dcterms:modified":"2024-03-02T20:55:23.295Z","cas:specializes":{"@id":"cas:Artifact"},"cas:enumeratedProperty":[{"@id":"cas:Diagram"},{"@id":"cas:Category"}],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"SpecIF:ModelElement","dcterms:title":[{"@value":"Model Element","@language":"en"},{"@value":"Modellelement","@language":"de"}],"skos:definition":[{"@value":"Is a generalized type for model elements.","@language":"en"},{"@value":"Ist ein generalisierter Typ für Modellelemente.","@language":"de"}],"cas:revision":"1.2","dcterms:modified":"2025-03-08T20:23:37.245Z","cas:specializes":{"@id":"cas:Artifact"},"cas:Icon":{"@value":"&#x2606;"},"cas:enumeratedProperty":[{"@id":"cas:Category"}],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"SpecIF:Collection","dcterms:title":[{"@value":"Collection or Group","@language":"en"},{"@value":"Kollektion oder Gruppe","@language":"de"},{"@value":"Collection ou Groupe","@language":"fr"}],"skos:definition":[{"@value":"<p>A 'Collection' is a logical (often conceptual) group of resources linked with a [[SpecIF:contains]] statement. It corresponds to a <a href=\"https://camunda.com/bpmn/reference/\">'Group'</a> in BPMN Diagrams.</p><p>BPMN: An arbitrary set of objects can be defined as a Group to show that they logically belong together. <small>(<i>source: <a href=\"http://www.bpmn-tool.com/en/tutorial/\">BPMN Tutorial</a></i>)</small></p>","@language":"en"},{"@value":"<p>Eine 'Kollektion' ist eine logische Gruppierung bestimmter Modellelemente, die per [[SpecIF:contains]] Relation zusammen gefasst sind. Sie entspricht einer <a href=\"https://camunda.com/bpmn/reference/\">'Gruppe'</a> in BPMN Diagrammen. <small>(<i>source: <a href=\"http://www.bpmn-tool.com/en/tutorial/\">BPMN Tutorial</a></i>)</small></p>","@language":"de"},{"@value":"<p>Une 'collection' est un groupe logique (souvent conceptuel) de ressources liées par une déclaration [[SpecIF:contains]]. Elle correspond à un <a href=\"https://camunda.com/bpmn/reference/\">'groupe'</a> dans les diagrammes BPMN. <small>(<i>source: <a href=\"http://www.bpmn-tool.com/en/tutorial/\">BPMN Tutoriel</a></i>)</small></p>","@language":"fr"}],"cas:revision":"1.2","dcterms:modified":"2024-06-09T18:27:41.176Z","cas:specializes":{"@id":"SpecIF:ModelElement"},"cas:Icon":{"@value":"⬚"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"o:RC-UmlDiagram","dcterms:title":[{"@value":"pig:View"}],"skos:definition":[{"@value":"<p>A 'Diagram' is a graphical model view with a specific communication purpose, e.g. a business process or system composition.</p>"}],"cas:revision":"1.2","dcterms:modified":"2025-11-09T11:47:24.726Z","cas:specializes":{"@id":"cas:Artifact"},"cas:Icon":{"@value":"▣"},"cas:enumeratedProperty":[{"@id":"cas:Diagram"},{"@id":"cas:Category"},{"@id":"cas:Notation"}],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"uml:Package","dcterms:title":[{"@value":"Package","@language":"en"}],"cas:revision":"1.2","dcterms:modified":"2024-06-13T07:55:07.739Z","cas:specializes":{"@id":"SpecIF:Collection"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"IREB:Requirement","dcterms:title":[{"@value":"Requirement","@language":"en"},{"@value":"Anforderung","@language":"de"},{"@value":"Exigence","@language":"fr"}],"skos:definition":[{"@value":"<p>A 'Requirement' is a singular documented physical and functional need that a particular design, product or process must be able to perform. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>A condition or capability needed by a user to solve a problem or achieve an objective.</li><li>A condition or capability that must be met or possessed by a system or system component to satisfy a contract, standard, specification, or other formally imposed documents.</li><li>A documented representation of a condition or capability as in (1) or (2).</li></ol><p>Note: The definition above is the classic one from IEEE Std 610.12 of 1990. Alternatively, we also give a more modern definition:</p><ol><li>A need perceived by a stakeholder.</li><li>A capability or property that a system shall have.</li><li>A documented representation of a need, capability or property.</li></ol>","@language":"en"},{"@value":"<p>Eine 'Anforderung' ist ein einzelnes dokumentiertes physisches und funktionales Bedürfnis, das ein bestimmter Entwurf, ein Produkt oder ein Prozess erfüllen muss. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Definition:</p><ol><li>Eine Bedingung oder Fähigkeit, die ein Benutzer benötigt, um ein Problem zu lösen oder ein Ziel zu erreichen.</li><li>Eine Bedingung oder Fähigkeit, die ein System oder eine Systemkomponente erfüllen oder besitzen muss, um einen Vertrag, eine Norm, eine Spezifikation oder ein anderes formal vorgeschriebenes Dokument zu erfüllen.</li><li>Eine dokumentierte Darstellung einer Bedingung oder Fähigkeit wie in (1) oder (2).</li></ol><p>Anmerkung: Die obige Definition ist die klassische Definition aus IEEE Std 610.12 von 1990. Alternativ geben wir auch eine modernere Definition an:</p><ol><li>Ein von einem Stakeholder wahrgenommener Bedarf.</li><li>Eine Fähigkeit oder Eigenschaft, die ein System haben soll.</li><li>Eine dokumentierte Darstellung eines Bedarfs, einer Fähigkeit oder Eigenschaft.</li></ol>","@language":"de"},{"@value":"<p>Une 'Exigence' est un besoin physique et fonctionnel unique et documenté qu'une conception, un produit ou un processus particulier doit pouvoir satisfaire. <small>(<i>source: <a href=\"https://en.wikipedia.org/wiki/Requirement\">Wikipedia</a></i>)</small></p><p>Définition:</p><ol><li>Condition ou capacité dont un utilisateur a besoin pour résoudre un problème ou atteindre un objectif.</li><li>Condition ou capacité qui doit être remplie ou possédée par un système ou un composant de système pour satisfaire à un contrat, à une norme, à une spécification ou à d'autres documents imposés officiellement.</li><li>Une représentation documentée d'une condition ou d'une capacité comme dans (1) ou (2).</li></ol><p>Remarque: La définition ci-dessus est la définition classique de la norme IEEE 610.12 de 1990. Nous donnons également une définition plus moderne:</p><ol><li>Un besoin perçu par une partie prenante;</li><li>Une capacité ou une propriété qu'un système doit avoir.</li><li>Une représentation documentée d'un besoin, d'une capacité ou d'une propriété.</li></ol>","@language":"fr"}],"cas:revision":"1.2","dcterms:modified":"2025-11-08T14:09:30.981Z","cas:specializes":{"@id":"cas:Artifact"},"cas:Icon":{"@value":"&#8623;"},"cas:enumeratedProperty":[{"@id":"cas:Category"}],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"o:RC-Paragraph-9846713279","dcterms:title":[{"@value":"SpecIF:Paragraph"}],"skos:definition":[{"@value":"<p>A 'Paragraph' is an unspecified information in a document at any level.</p>","@language":"en"},{"@value":"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>","@language":"de"}],"cas:revision":"1.1","dcterms:modified":"2024-03-02T20:55:23.295Z","cas:specializes":{"@id":"cas:Artifact"},"cas:enumeratedProperty":[{"@id":"o:PC-Diagram-9846713279"},{"@id":"cas:Category"}],"cas:itemType":{"@id":"cas:Entity"}},{"@id":"SpecIF:relates","dcterms:title":[{"@value":"relates","@language":"en"},{"@value":"verbindet","@language":"de"},{"@value":"relie","@language":"fr"}],"skos:definition":[{"@value":"Is a generalized type for model relations.","@language":"en"},{"@value":"Ist ein generalisierter Typ für Modellrelationen.","@language":"de"}],"cas:revision":"1.2","dcterms:modified":"2024-06-09T12:35:33.150Z","cas:specializes":{"@id":"cas:Relationship"},"cas:enumeratedProperty":[{"@id":"cas:Category"}],"cas:itemType":{"@id":"cas:Relationship"},"cas:enumeratedSourceLink":{"@id":"SpecIF:relates-toSource"},"cas:enumeratedTargetLink":{"@id":"SpecIF:relates-toTarget"}},{"@id":"SpecIF:relates-toSource","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:SourceLink"},"dcterms:title":[{"@value":"SpecIF:relates to source"}],"dcterms:description":[{"@value":"Connects the source of SpecIF:relates"}],"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}]},{"@id":"SpecIF:relates-toTarget","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:TargetLink"},"dcterms:title":[{"@value":"SpecIF:relates to target"}],"dcterms:description":[{"@value":"Connects the target of SpecIF:relates"}],"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}]},{"@id":"SpecIF:contains","dcterms:title":[{"@value":"contains","@language":"en"},{"@value":"enthält","@language":"de"},{"@value":"contient","@language":"fr"}],"skos:definition":[{"@value":"General containment, such as:\n- Package-A *contains* Diagram-B\n- Collection-1 *contains* DataObject-1.1\n\nNot to confound with *[[dcterms:hasPart]]*.","@language":"en"}],"cas:revision":"1.1","dcterms:modified":"2024-06-18T12:22:11.959Z","cas:specializes":{"@id":"SpecIF:relates"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Relationship"},"cas:enumeratedSourceLink":{"@id":"SpecIF:contains-toSource"},"cas:enumeratedTargetLink":{"@id":"SpecIF:contains-toTarget"}},{"@id":"SpecIF:contains-toSource","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:SourceLink"},"dcterms:title":[{"@value":"SpecIF:contains to source"}],"dcterms:description":[{"@value":"Connects the source of SpecIF:contains"}],"cas:enumeratedEndpoint":[{"@id":"FMC:Actor"},{"@id":"FMC:State"},{"@id":"SpecIF:Collection"},{"@id":"uml:Package"}]},{"@id":"SpecIF:contains-toTarget","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:TargetLink"},"dcterms:title":[{"@value":"SpecIF:contains to target"}],"dcterms:description":[{"@value":"Connects the target of SpecIF:contains"}],"cas:enumeratedEndpoint":[{"@id":"FMC:Actor"},{"@id":"FMC:State"},{"@id":"FMC:Event"},{"@id":"SpecIF:Collection"},{"@id":"uml:Package"},{"@id":"SpecIF:ModelElement"},{"@id":"o:RC-SpecifView"},{"@id":"o:RC-PigView"},{"@id":"o:RC-UmlDiagram"},{"@id":"IREB:Requirement"}]},{"@id":"oslc_rm:satisfies","dcterms:title":[{"@value":"satisfies","@language":"en"},{"@value":"erfüllt","@language":"de"},{"@value":"satisfait","@language":"fr"}],"skos:definition":[{"@value":"<p>The object is satisfied by the subject. <small>(<i>source: <a href=\"http://open-services.net/\">OSLC</a></i>)</small></p><p>SpecIF suggests that the subject is confined to a model element, e.g, a [[FMC:Actor]] or [[FMC:State]], and the object is confined to a [[IREB:Requirement]]. More concretely, an example for this type of statement is 'Component-X <em>satisfies</em> 'Requirement-4711'.</p>","@language":"en"}],"cas:revision":"1.2","dcterms:modified":"2024-06-14T06:49:03.417Z","cas:specializes":{"@id":"cas:Relationship"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Relationship"},"cas:enumeratedSourceLink":{"@id":"oslc_rm:satisfies-toSource"},"cas:enumeratedTargetLink":{"@id":"oslc_rm:satisfies-toTarget"}},{"@id":"oslc_rm:satisfies-toSource","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:SourceLink"},"dcterms:title":[{"@value":"oslc_rm:satisfies to source"}],"dcterms:description":[{"@value":"Connects the source of oslc_rm:satisfies"}],"cas:enumeratedEndpoint":[{"@id":"cas:Entity"},{"@id":"cas:Relationship"}]},{"@id":"oslc_rm:satisfies-toTarget","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:TargetLink"},"dcterms:title":[{"@value":"oslc_rm:satisfies to target"}],"dcterms:description":[{"@value":"Connects the target of oslc_rm:satisfies"}],"cas:enumeratedEndpoint":[{"@id":"IREB:Requirement"}]},{"@id":"IREB:refines","dcterms:title":[{"@value":"refines","@language":"en"},{"@value":"verfeinert","@language":"de"},{"@value":"affine","@language":"fr"}],"skos:definition":[{"@value":"<p>A [[IREB:Requirement]] 'refines' another [[IREB:Requirement]].</p>","@language":"en"}],"cas:revision":"1.2","dcterms:modified":"2024-06-14T06:40:52.155Z","cas:specializes":{"@id":"cas:Relationship"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Relationship"},"cas:enumeratedSourceLink":{"@id":"IREB:refines-toSource"},"cas:enumeratedTargetLink":{"@id":"IREB:refines-toTarget"}},{"@id":"IREB:refines-toSource","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:SourceLink"},"dcterms:title":[{"@value":"IREB:refines to source"}],"dcterms:description":[{"@value":"Connects the source of IREB:refines"}],"cas:enumeratedEndpoint":[{"@id":"IREB:Requirement"}]},{"@id":"IREB:refines-toTarget","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:TargetLink"},"dcterms:title":[{"@value":"IREB:refines to target"}],"dcterms:description":[{"@value":"Connects the target of IREB:refines"}],"cas:enumeratedEndpoint":[{"@id":"IREB:Requirement"}]},{"@id":"sysml:Allocate","dcterms:title":[{"@value":"is allocated to","@language":"en"},{"@value":"zugeordnet zu","@language":"de"},{"@value":"allouée à","@language":"fr"}],"skos:definition":[{"@value":"<p>An [[FMC:Actor]] is allocated to another [[FMC:Actor]] (e.g. a logical function is allocated to a physical component.</p>","@language":"en"}],"cas:revision":"1.2","dcterms:modified":"2025-09-06T14:59:03.739Z","cas:specializes":{"@id":"cas:Relationship"},"cas:enumeratedProperty":[],"cas:itemType":{"@id":"cas:Relationship"},"cas:enumeratedSourceLink":{"@id":"sysml:Allocate-toSource"},"cas:enumeratedTargetLink":{"@id":"sysml:Allocate-toTarget"}},{"@id":"sysml:Allocate-toSource","cas:itemType":{"@id":"cas:Link"},"cas:specializes":{"@id":"cas:SourceLink"},"dcterms:title":[{"@value":"sysml:A