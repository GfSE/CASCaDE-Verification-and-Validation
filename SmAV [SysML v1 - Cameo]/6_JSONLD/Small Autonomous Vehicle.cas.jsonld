C to the target location T by means of a road map and actual traffic conditions."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552810869277_586147_14175","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Road Driving"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"The vehicle shall be able to follow a selected road."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552810644650_650036_14079","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Transport to Target"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"As a customer I would like to get a parcel delivered from the current location C to a target location T. "}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552812370943_152244_14924","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Location as Postal Address"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"A location may be specified as a postal address."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552813199775_830344_15281","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Obstacle Avoidance"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"The vehicle shall not hit a person or an obstacle on the road."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552810948738_707540_14217","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Safe Driving"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"The vehicle shall drive no faster than allowed or adequate for the actual road condition."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552812437056_257578_14975","@type":"IREB:Requirement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Loacation as GPS Coordinate"}],"cas:Category":[{"@value":"uml:Class","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"A location may be specified as GPS Coordinate with Longitude and Latitude in Degrees."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_19_0_3_71e0233_1746001480225_327746_14120","@type":"uml:Package","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"2. Functional Layer"}],"cas:Category":[{"@value":"uml:Package","cas:itemType":{"@id":"cas:aProperty"}}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552811870216_105923_14824","@type":"o:RC-UmlDiagram","cas:revision":"rev-11094738149","dcterms:modified":"2025-11-12T09:28:21.131Z","dcterms:title":[{"@value":"Functional Decomposition"}],"cas:Diagram":[{"@value":"<object data=\"files_and_images/Functional Decomposition.png\" type=\"image/png\">files_and_images/Functional Decomposition.png</object>","cas:itemType":{"@id":"cas:aProperty"}}],"cas:Category":[{"@value":"uml:Diagram","cas:itemType":{"@id":"cas:aProperty"}}],"cas:Notation":[{"@value":"SysML Block Definition Diagram","cas:itemType":{"@id":"cas:aProperty"}}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552813556602_820961_15353","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Brake in an Emergency"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"Take the vehicle to a full stop in the shortest time possible without loosing control over the trajectory."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552814212889_663150_15729","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Set Speed"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"The (autonomous) driver's speed command (gas pedal position)."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1556615164506_303870_14975","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Turn Right"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"Take a right turn at a road intersection. Observe the traffic entering the same lane and avoid a collision, if another vehicle does not observe the priority rules."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552814194319_862392_15683","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Set Radius"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"The (autonomous) driver's steering command (steering wheel position)."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552812663506_709974_15011","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Navigate"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"dcterms:description":[{"@value":"Select a path to get from the current position to the target."}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1552814523707_628151_15988","@type":"SpecIF:ModelElement","dcterms:modified":"2025-09-24T08:28:08.223Z","dcterms:title":[{"@value":"Calculate Accelerations"}],"cas:Category":[{"@value":"RFLP:Function","cas:itemType":{"@id":"cas:aProperty"}}],"cas:itemType":{"@id":"cas:anEntity"}},{"@id":"d:_18_5_3_bc402f4_1556615212765_548060_15021","@type":"S