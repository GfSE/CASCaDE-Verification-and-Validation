	rdfs:label "Stakeholder Group"@en ;
	skos:definition "Enumerated values for the 'Stakehoder Group' addressed by the term."@en ;
	rdfs:range SpecIF:StakeholderGroup-Enumeration .

casShapes_SpecIF:StakeholderGroup
	rdf:type sh:PropertyShape ;
	sh:path SpecIF:StakeholderGroup ;
	sh:maxCount "1" ;
	sh:class SpecIF:StakeholderGroup-Enumeration .

cas:Icon
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "icon" .

casShapes_cas:Icon
	rdf:type sh:PropertyShape ;
	sh:path cas:Icon ;
	sh:maxCount "1" ;
	sh:datatype xs:string ;
	sh:maxLength "256" .

IREB:RequirementType
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:label "Type"@en ,
		"Art"@de ;
	skos:definition "According to the IREB, requirements are typically classified into functional requirements ([[IREB:FunctionalRequirement]]), quality requirements ([[IREB:QualityRequirement]]) and constraints ([[IREB:Constraint]]). The latter two are also called non-functional requirements."@en ,
		"Nach dem IREB werden Anforderungen üblicherweise nach 'Art' in funktionale Anforderungen ([[IREB:FunctionalRequirement]]), Qualitätsanforderungen ([[IREB:QualityRequirement]]) und Randbedingungen ([[IREB:Constraint]]) unterteilt. Die beiden letzteren werden auch nicht-funktionale Anforderungen genannt."@de ,
		"Selon l'IREB, les exigences sont généralement classées en exigences fonctionnelles ([[IREB:FunctionalRequirement]]), en exigences de qualité ([[IREB:QualityRequirement]]) et en contraintes ([[IREB:Constraint]]). Ces deux dernières sont également appelées exigences non fonctionnelles."@fr ;
	rdfs:range IREB:RequirementType-Enumeration .

casShapes_IREB:RequirementType
	rdf:type sh:PropertyShape ;
	sh:path IREB:RequirementType ;
	sh:maxCount "1" ;
	sh:class IREB:RequirementType-Enumeration .

o:PC-Diagram-10478717701
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "cas:Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

o:PC-Diagram-10478717701_shape
	rdf:type sh:PropertyShape ;
	sh:path o:PC-Diagram-10478717701 ;
	sh:datatype xs:string .

#################################################################
# Ontology - Entity Classes
#################################################################

SpecIF:Paragraph
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Paragraph"@en ,
		"Textabsatz"@de ,
		"Paragraphe"@fr ;
	skos:definition "<p>A 'Paragraph' is an unspecified information in a document at any level.</p>"@en ,
		"<p>Ein 'Textabschnitt' in einem Dokument auf beliebiger Ebene.</p>"@de .

casShapes_SpecIF:Paragraph
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:Paragraph ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Category .

o:RC-PigElement
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "pig:Element" ;
	skos:definition "An abstract superclass for pig:Organizer, pig:Entity and pig:Relationship" .

o:RC-PigElement_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-PigElement ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:Icon .

o:RC-PigOrganizer
	rdf:type owl:Class ;
	rdfs:subClassOf o:RC-PigElement ;
	rdfs:label "pig:Organizer" ;
	skos:definition "A hierarchical organizer such as an outline or diagram referencing model-elements." .

o:RC-PigOrganizer_shape
	rdf:type sh:NodeShape ;
	sh:targetClass o:RC-PigOrganizer ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:Icon .

SpecIF:ModelElement
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Model Element"@en ,
		"Modellelement"@de ;
	skos:definition "Is a generalized type for model elements."@en ,
		"Ist ein generalisierter Typ für Modellelemente."@de ;
	cas:Icon "&#x2606;" .

casShapes_SpecIF:ModelElement
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:ModelElement ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

o:RC-SpecifView
	rdf:type owl:Class ;
	rdfs:subClassOf SpecIF:Paragraph ;
	rdfs:label "pig:View" ;
	skos:definition "<p>A 'Model View' is a graphical diagram with a specific communication purpose, e.g. a business process or system composition. A suitable notation is applied.</p>" ;
	cas:Icon "▣" .

o:RC-SpecifView_shape
