#################################################################
# Ontology - Relationship Classes
#################################################################

SpecIF:relates
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "relates"@en ,
		"verbindet"@de ,
		"relie"@fr ;
	skos:definition "Is a generalized type for model relations."@en ,
		"Ist ein generalisierter Typ für Modellrelationen."@de ;
	dcterms:modified "2024-06-09T12:35:33.150Z" .

SpecIF:relates-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "SpecIF:relates to source" ;
	rdfs:comment "Connects the source of SpecIF:relates" ;
	rdfs:domain SpecIF:relates .

SpecIF:relates-toTarget
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:label "SpecIF:relates to target" ;
	rdfs:comment "Connects the target of SpecIF:relates" ;
	rdfs:domain SpecIF:relates .

casShapes_SpecIF:relates
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:relates ;
	sh:property casShapes_cas:Category ;
	sh:property [ 
		sh:path SpecIF:relates-toSource ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path SpecIF:relates-toTarget ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

dcterms:hasPart
	rdf:type owl:Class ;
	rdfs:subClassOf SpecIF:relates ;
	rdfs:label "has part"@en ,
		"enthält"@de ,
		"contient"@fr ;
	skos:definition "A related resource that is included either physically or logically in the described resource.\n\n*Comment: This property is intended to be used with non-literal values. This property is an inverse property of [[dcterms:isPartOf]].*"@en ;
	dcterms:modified "2024-06-18T12:23:12.163Z" .

dcterms:hasPart-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "dcterms:hasPart to source" ;
	rdfs:comment "Connects the source of dcterms:hasPart" ;
	rdfs:domain dcterms:hasPart ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
			SpecIF:Collection
			SpecIF:ModelElement
			o:RC-UmlClass
		)] .

dcterms:hasPart-toTarget
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:label "dcterms:hasPart to target" ;
	rdfs:comment "Connects the target of dcterms:hasPart" ;
	rdfs:domain dcterms:hasPart ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
			SpecIF:Collection
			SpecIF:ModelElement
			uml:Port
			o:RC-UmlClass
		)] .

casShapes_dcterms:hasPart
	rdf:type sh:NodeShape ;
	sh:targetClass dcterms:hasPart ;
	sh:property casShapes_cas:Category ;
	sh:property [ 
		sh:path dcterms:hasPart-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
			[ sh:class SpecIF:Collection ]
			[ sh:class SpecIF:ModelElement ]
			[ sh:class o:RC-UmlClass ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path dcterms:hasPart-toTarget ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
			[ sh:class SpecIF:Collection ]
			[ sh:class SpecIF:ModelElement ]
			[ sh:class uml:Port ]
			[ sh:class o:RC-UmlClass ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

SpecIF:contains
	rdf:type owl:Class ;
	rdfs:subClassOf SpecIF:relates ;
	rdfs:label "contains"@en ,
		"enthält"@de ,
		"contient"@fr ;
	skos:definition "General containment, such as:\n- Package-A *contains* Diagram-B\n- Collection-1 *contains* DataObject-1.1\n\nNot to confound with *[[dcterms:hasPart]]*."@en ;
	dcterms:modified "2024-06-18T12:22:11.959Z" .

SpecIF:contains-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "SpecIF:contains to source" ;
	rdfs:comment "Connects the source of SpecIF:contains" ;
	rdfs:domain SpecIF:contains ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
			SpecIF:Collection
			uml:Package
		)] .

SpecIF:contains-toTarget
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:label "SpecIF:contains to target" ;
	rdfs:comment "Connects the target of SpecIF:contains" ;
	rdfs:domain SpecIF:contains ;
	rdfs:range [ owl:unionOf(
			FMC:Actor
			FMC:State
			FMC:Event
			SpecIF:Collection
			uml:Package
			SpecIF:ModelElement
			o:RC-SpecifView
		)] .

casShapes_SpecIF:contains
	rdf:type sh:NodeShape ;
	sh:targetClass SpecIF:contains ;
	sh:property casShapes_cas:Category ;
	sh:property [ 
		sh:path SpecIF:contains-toSource ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
			[ sh:class SpecIF:Collection ]
			[ sh:class uml:Package ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] ;
	sh:property [ 
		sh:path SpecIF:contains-toTarget ;
		sh:or (
			[ sh:class FMC:Actor ]
			[ sh:class FMC:State ]
			[ sh:class FMC:Event ]
			[ sh:class SpecIF:Collection ]
			[ sh:class uml:Package ]
			[ sh:class SpecIF:ModelElement ]
			[ sh:class o:RC-SpecifView ]
		) ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

oslc_rm:satisfies
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "satisfies"@en ,
		"erfüllt"@de ,
		"satisfait"@fr ;
	skos:definition "<p>The object is satisfied by the subject. <small>(<i>source: <a href=\"http://open-services.net/\">OSLC</a></i>)</small></p><p>SpecIF suggests that the subject is confined to a model element, e.g, a [[FMC:Actor]] or [[FMC:State]], and the object is confined to a [[IREB:Requirement]]. More concretely, an example for this type of statement is 'Component-X <em>satisfies</em> 'Requirement-4711'.</p>"@en ;
	dcterms:modified "2024-06-14T06:49:03.417Z" .

oslc_rm:satisfies-toSource
	rdfs:subPropertyOf cas:SourceLink ;
	rdfs:label "oslc_rm:satisfies to source" ;
	rdfs:comment "Connects the source of oslc_rm:satisfies" ;
	rdfs:domain oslc_rm:satisfies .

oslc_rm:satisfies-toTarget
