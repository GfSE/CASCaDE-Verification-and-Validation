	rdf:type owl:Class ;
	rdfs:subClassOf cas:Relationship ;
	rdfs:label "is allocated to"@en ,
		"zugeordnet zu"@de ,
		"allouée à"@fr ;
	skos:definition "<p>An [[FMC:Actor]] is allocated to another [[FMC:Actor]] (e.g. a logical function is allocated to a physical component.</p>"@en ;
