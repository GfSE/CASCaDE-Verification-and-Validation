
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <https://www.w3.org/TR/skos-reference/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xs: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix casShapes_dcterms: <https://product-information-graph.org/v0.2/ontology/shapes/dcterms#> .
@prefix FMC: <http://fmc-modeling.org#> .
@prefix casShapes_FMC: <https://product-information-graph.org/v0.2/ontology/shapes/FMC#> .
@prefix RFLP: <https://product-information-graph.org/v0.2/ontology/RFLP#> .
@prefix casShapes_RFLP: <https://product-information-graph.org/v0.2/ontology/shapes/RFLP#> .
@prefix IREB: <https://cpre.ireb.org/en/downloads-and-resources/glossary#> .
@prefix casShapes_IREB: <https://product-information-graph.org/v0.2/ontology/shapes/IREB#> .
@prefix ReqIF: <https://www.prostep.org/fileadmin/downloads/PSI_ImplementationGuide_ReqIF_V1-7.pdf#> .
@prefix casShapes_ReqIF: <https://product-information-graph.org/v0.2/ontology/shapes/ReqIF#> .
@prefix oslc_rm: <http://open-services.net/ns/rm#> .
@prefix casShapes_oslc_rm: <https://product-information-graph.org/v0.2/ontology/shapes/oslc_rm#> .
@prefix uml: <https://www.omg.org/spec/UML#> .
@prefix casShapes_uml: <https://product-information-graph.org/v0.2/ontology/shapes/uml#> .
@prefix sysml: <https://www.omg.org/spec/SysML#> .
@prefix casShapes_sysml: <https://product-information-graph.org/v0.2/ontology/shapes/sysml#> .
@prefix cas: <https://product-information-graph.org/v0.2/metamodel#> .
@prefix casShapes_cas: <https://product-information-graph.org/v0.2/ontology/shapes/cas#> .
@prefix SpecIF: <https://specif.de/v1.2/schema#> .
@prefix casShapes_SpecIF: <https://product-information-graph.org/v0.2/ontology/shapes/SpecIF#> .

@prefix o: <https://product-information-graph.org/v0.2/ontology#> .
@prefix d: <https://product-information-graph.org/examples/Small%20Autonomous%20Vehicle.specif.zip#> .

#################################################################
# Project Metadata
#################################################################

d:
	rdf:type owl:Ontology ;
	rdfs:label "Small Autonomous Vehicle" ;
	rdfs:comment "A set of SpecIF Classes derived from a SpecIF Ontology for the domains SpecIF:DomainBase, SpecIF:DomainSystemsEngineering, SpecIF:DomainSystemModelIntegration."@en ;
	owl:imports <http://www.w3.org/1999/02/22-rdf-syntax-ns#> ,
		<http://www.w3.org/2000/01/rdf-schema#> ;
	dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
	dcterms:modified "2026-05-11T10:02:23.879Z" .

#################################################################
# CASCaRA Metamodel and Semantic Infrastructure
#################################################################

cas:Enumeration
	rdf:type owl:Class ;
	rdfs:label "Enumeration" ;
	skos:definition "A CASCaRA meta-model item used for value enumerations." .

casShapes_cas:Enumeration
	rdf:type sh:NodeShape .

cas:Entity
	rdf:type owl:Class ;
	rdfs:label "Entity" ;
	skos:definition "A CASCaRA meta-model item used for entities (aka resources or artifacts)." .

casShapes_cas:Entity
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Entity ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category .

cas:Organizer
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Entity ;
	rdfs:label "Organizer" ;
	skos:definition "A CASCaRA meta-model item for organizing model-elements. An example is a list of requirements or a diagram using a certain notation." .

casShapes_cas:Organizer
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Organizer ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Package
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Package" ;
	skos:definition "A subclass of cas:Organizer used for a partial graph selected for exchange or access permissions." .

casShapes_cas:Package
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Package ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:Root
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Root" ;
	skos:definition "A subclass of cas:Organizer serving as a root for trees and tables." .

casShapes_cas:Root
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Root ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Tree
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Tree" ;
	skos:definition "A subclass of cas:Organizer for strictly hierarchical data structures referencing entities and relationships." .

casShapes_cas:Tree
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Tree ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:lists .

cas:Outline
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Tree ;
	rdfs:label "Outline" ;
	skos:definition "A subclass of cas:Tree comprising all information items of a human-readable document. As usual, the outline is hierarchically organized." .

casShapes_cas:Outline
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Outline ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] .

cas:View
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "View" ;
	skos:definition "A subclass of cas:Organizer representing a model view (diagram) using a certain notation showing selected model elements." .

casShapes_cas:View
	rdf:type sh:NodeShape ;
	sh:targetClass cas:View ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Diagram ,
		casShapes_cas:Notation ,
		casShapes_cas:Category ,
		casShapes_cas:shows ,
		casShapes_cas:depicts .

cas:Table
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Organizer ;
	rdfs:label "Table" ;
	skos:definition "A subclass of cas:Organizer representing a table showing selected model elements." .

casShapes_cas:Table
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Table ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:shows .

cas:Relationship
	rdf:type owl:Class ;
	rdfs:label "Relationship" ;
	skos:definition "A CASCaRA meta-model item used for reified relationships (aka predicates)." .

casShapes_cas:Relationship
	rdf:type sh:NodeShape ;
	sh:targetClass cas:Relationship ;
	sh:property [ 
		sh:path rdfs:label ;
		sh:minCount 1
	] ,
		[ 
		sh:path rdfs:comment ;
		sh:minCount 1
	] ,
		casShapes_cas:Category ,
		casShapes_cas:SourceLink ,
		casShapes_cas:TargetLink .

cas:Property
	rdf:type owl:DatatypeProperty ;
	rdfs:label "Property" ;
	skos:definition "A CASCaRA meta-model item used for properties (aka attributes)." .

casShapes_cas:Property
	rdf:type sh:PropertyShape ;
	sh:path cas:Property ;
	sh:datatype xs:anyType .

cas:Diagram
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "Diagram" ;
	skos:definition "A diagram illustrating the resource or a link to a diagram." .

casShapes_cas:Diagram
	rdf:type sh:PropertyShape ;
	sh:path cas:Diagram ;
	sh:datatype xs:string ;
	sh:minCount "0" .

cas:Category
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Property ;
	rdfs:label "has category" ;
	skos:definition "Specifies a category for an element (entity, relationship or organizer)." .

casShapes_cas:Category
	rdf:type sh:PropertyShape ;
	sh:path cas:Category ;
	sh:datatype xs:string ;
	sh:maxLength "32" ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Notation
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf cas:Category ;
	rdfs:label "Notation" ;
	skos:definition "A reference to a notation defining the syntax and semantics of a diagram." .

casShapes_cas:Notation
	rdf:type sh:PropertyShape ;
	sh:path cas:Notation ;
	sh:datatype xs:string ;
	sh:minCount "0" ;
	sh:maxCount "1" .

cas:Link
	rdf:type owl:ObjectProperty ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "linked with" ;
	skos:definition "A PIG meta-model item connecting a reified relationship with its source or target. Also connects an organizer to a model element." .

casShapes_cas:Link
	rdf:type sh:PropertyShape ;
	sh:path cas:Link ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:SourceLink
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to source" ;
	skos:definition "Connects the source of a reified relationship." .

casShapes_cas:SourceLink
	rdf:type sh:PropertyShape ;
	sh:path cas:SourceLink ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:TargetLink
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:Link ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "to target" ;
	skos:definition "Connects the target of a reified relationship or an organizer." .

casShapes_cas:TargetLink
	rdf:type sh:PropertyShape ;
	sh:path cas:TargetLink ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:lists
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
			cas:Organizer
		)] ;
	rdfs:label "lists" ;
	skos:definition "Lists an entity, a relationship or a subordinated organizer." .

casShapes_cas:lists
	rdf:type sh:PropertyShape ;
	sh:path cas:lists ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
			[ sh:class cas:Organizer ]
		) .

cas:shows
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range [ owl:unionOf(
			cas:Entity
			cas:Relationship
		)] ;
	rdfs:label "shows" ;
	skos:definition "Shows an entity or a relationship." .

casShapes_cas:shows
	rdf:type sh:PropertyShape ;
	sh:path cas:shows ;
	sh:or (
			[ sh:class cas:Entity ]
			[ sh:class cas:Relationship ]
		) .

cas:depicts
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf cas:TargetLink ;
	rdfs:range cas:Entity ;
	rdfs:label "depicts" ;
	skos:definition "Depicts an entity; inverse of uml:ownedDiagram." .

casShapes_cas:depicts
	rdf:type sh:PropertyShape ;
	sh:path cas:depicts ;
	sh:or (
			[ sh:class cas:Entity ]
		) .

#################################################################
# Data Types with Enumerated Values
#################################################################

SpecIF:Priority-Enumeration
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Enumeration ;
	rdfs:label "Priority"@en ,
		"Priorität"@de ,
		"Priorité"@fr ;
	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	dcterms:modified "2025-09-05T12:40:27.574Z" ;
	sh:datatype xs:string ;
	owl:oneOf (
			SpecIF:priorityHigh
			SpecIF:priorityRatherHigh
			SpecIF:priorityMedium
			SpecIF:priorityRatherLow
			SpecIF:priorityLow
		) .
SpecIF:priorityHigh
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "high"@en ,
		"hoch"@de ,
		"haut"@fr .
SpecIF:priorityRatherHigh
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "rather high"@en ,
		"eher hoch"@de ,
		"plutôt haut"@fr .
SpecIF:priorityMedium
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "medium"@en ,
		"mittel"@de ,
		"moyen"@fr .
SpecIF:priorityRatherLow
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "rather low"@en ,
		"eher niedrig"@de ,
		"plutôt bas"@fr .
SpecIF:priorityLow
	rdf:type SpecIF:Priority-Enumeration ;
	rdfs:label "low"@en ,
		"niedrig"@de ,
		"bas"@fr .

SpecIF:StakeholderGroup-Enumeration
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Enumeration ;
	rdfs:label "Stakeholder Group"@en ;
	skos:definition "Enumerated values for the 'Stakehoder Group' addressed by the term."@en ;
	dcterms:modified "2023-03-10T07:48:02.442Z" ;
	sh:datatype xs:string ;
	owl:oneOf (
			SpecIF:StakeholderGroupRegulation
			SpecIF:StakeholderGroupBusiness
			SpecIF:StakeholderGroupUser
			SpecIF:StakeholderGroupSystem
			SpecIF:StakeholderGroupOperation
		) .
SpecIF:StakeholderGroupRegulation
	rdf:type SpecIF:StakeholderGroup-Enumeration ;
	rdfs:label "Regulation"@en .
SpecIF:StakeholderGroupBusiness
	rdf:type SpecIF:StakeholderGroup-Enumeration ;
	rdfs:label "Business"@en .
SpecIF:StakeholderGroupUser
	rdf:type SpecIF:StakeholderGroup-Enumeration ;
	rdfs:label "User"@en .
SpecIF:StakeholderGroupSystem
	rdf:type SpecIF:StakeholderGroup-Enumeration ;
	rdfs:label "System"@en .
SpecIF:StakeholderGroupOperation
	rdf:type SpecIF:StakeholderGroup-Enumeration ;
	rdfs:label "Operation"@en .

IREB:RequirementType-Enumeration
	rdf:type owl:Class ;
	rdfs:subClassOf cas:Enumeration ;
	rdfs:label "Type"@en ,
		"Art"@de ;
	skos:definition "According to the IREB, requirements are typically classified into functional requirements ([[IREB:FunctionalRequirement]]), quality requirements ([[IREB:QualityRequirement]]) and constraints ([[IREB:Constraint]]). The latter two are also called non-functional requirements."@en ,
		"Nach dem IREB werden Anforderungen üblicherweise nach 'Art' in funktionale Anforderungen ([[IREB:FunctionalRequirement]]), Qualitätsanforderungen ([[IREB:QualityRequirement]]) und Randbedingungen ([[IREB:Constraint]]) unterteilt. Die beiden letzteren werden auch nicht-funktionale Anforderungen genannt."@de ,
		"Selon l'IREB, les exigences sont généralement classées en exigences fonctionnelles ([[IREB:FunctionalRequirement]]), en exigences de qualité ([[IREB:QualityRequirement]]) et en contraintes ([[IREB:Constraint]]). Ces deux dernières sont également appelées exigences non fonctionnelles."@fr ;
	dcterms:modified "2023-08-08T20:52:31.633Z" ;
	sh:datatype xs:string ;
	owl:oneOf (
			o:V-RequirementType-0
			o:V-RequirementType-1
			IREB:FunctionalRequirement
			IREB:QualityRequirement
			IREB:Constraint
			o:V-RequirementType-5
		) .
o:V-RequirementType-0
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "SpecIF:Feature" .
o:V-RequirementType-1
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "SpecIF:UserStory" .
IREB:FunctionalRequirement
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "Functional Requirement"@en ,
		"Funktionsanforderung"@de ,
		"Exigence de function"@fr .
IREB:QualityRequirement
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "Quality Requirement"@en ,
		"Qualitätsanforderung"@de ,
		"Exigence de qualité"@fr .
IREB:Constraint
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "Constraint"@en ,
		"Randbedingung"@de ,
		"Contrainte"@fr .
o:V-RequirementType-5
	rdf:type IREB:RequirementType-Enumeration ;
	rdfs:label "SpecIF:PainPoint" .

