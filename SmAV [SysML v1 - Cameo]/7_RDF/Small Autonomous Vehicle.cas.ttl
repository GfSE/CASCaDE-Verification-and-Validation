	skos:definition "Enumerated values for the 'Priority' of the resource."@en ;
	rdfs:range SpecIF:Priority-Enumeration .

casShapes_SpecIF:Priority
	rdf:type sh:PropertyShape ;
	sh:path SpecIF:Priority ;
